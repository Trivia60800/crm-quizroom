  }
  const n = _selectedMediaIds.size;
  const countEl = document.getElementById('media-sel-count');
  const labelEl = document.getElementById('media-sel-count-label');
  if (countEl) countEl.textContent = n;
  if (labelEl) labelEl.textContent = n > 0 ? `${n} fichier(s) sélectionné(s)` : 'Aucun fichier sélectionné';
}

