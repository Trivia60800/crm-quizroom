function _initDropzone() {
  const zone = document.getElementById('media-dropzone');
  if (!zone || zone._dzInited) return;
  zone._dzInited = true;

  zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('dragover'); });
  zone.addEventListener('dragleave', ()  => zone.classList.remove('dragover'));
  zone.addEventListener('drop', async e => {
    e.preventDefault();
    zone.classList.remove('dragover');
    const files = Array.from(e.dataTransfer?.files || []);
    if (files.length) await _uploadFiles(files);
  });
}

/* ────────────────────────────────────────────────────────────────
   UPLOAD
──────────────────────────────────────────────────────────────── */
async function handleMediaUpload(event) {
  const files = Array.from(event.target.files || []);
  if (!files.length) return;
  await _uploadFiles(files);
  event.target.value = ''; // reset input
}

async function _uploadFiles(files) {
  showLoader(`Upload de ${files.length} fichier(s)…`);
  let ok = 0, errors = 0;

  for (const file of files) {
    const safeName = file.name.replace(/\s+/g, '_').replace(/[^a-zA-Z0-9._-]/g, '');
    const path     = `global/${Date.now()}_${safeName}`;

    try {
      /* 1. Upload Supabase Storage */
      const { error: storageErr } = await _sb.storage
        .from('crm-files')
        .upload(path, file, { contentType: file.type, upsert: false });

      if (storageErr) throw new Error(storageErr.message);

      /* 2. Métadonnées en base */
      const { error: dbErr } = await _sb.from('files').insert([{
        name:         file.name,
        category:     _detectCategory(file.name, file.type),
        storage_path: path,
        size_bytes:   file.size,
        mime_type:    file.type,
      }]);

      if (dbErr) {
        // Tenter de nettoyer le storage si la BDD échoue
        await _sb.storage.from('crm-files').remove([path]);
        throw new Error(dbErr.message);
      }
      ok++;
    } catch (e) {
      console.error('[upload]', file.name, e.message);
      errors++;
    }
  }

  hideLoader();
  showToast(
    `${ok} fichier(s) uploadé(s)${errors ? ` — ${errors} erreur(s)` : ''}`,
    errors > 0 ? 'warning' : 'success'
  );

  _mediaFiles = await _fetchFiles();
  _rebuildMediatheque();
}

/* ────────────────────────────────────────────────────────────────
   TÉLÉCHARGER
──────────────────────────────────────────────────────────────── */
async function downloadMediaFile(fileId) {
  const file = _mediaFiles.find(f => f.id === fileId);
  if (!file) { showToast('Fichier introuvable', 'error'); return; }

  showLoader('Téléchargement…');
  try {
    const { data, error } = await _sb.storage
      .from('crm-files')
      .download(file.storage_path);

    if (error) throw new Error(error.message);

    const url = URL.createObjectURL(data);
    const a   = document.createElement('a');
    a.href    = url;
    a.download = file.name;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  } catch (e) {
    showToast('Erreur téléchargement : ' + e.message, 'error');
  } finally {
    hideLoader();
  }
}

/* ────────────────────────────────────────────────────────────────
   RÉCUPÉRER EN BASE64 (pour pièces jointes email)
──────────────────────────────────────────────────────────────── */
async function fetchFileAsBase64(fileId) {
  const file = _mediaFiles.find(f => f.id === fileId);
  if (!file) return null;

  const { data, error } = await _sb.storage
    .from('crm-files')
    .download(file.storage_path);

  if (error || !data) return null;

  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload  = e => {
      const b64 = e.target.result.split(',')[1]; // retirer le préfixe data:...;base64,
      resolve({ name: file.name, mimeType: file.mime_type, data: b64 });
    };
    reader.onerror = reject;
    reader.readAsDataURL(data);
  });
}

