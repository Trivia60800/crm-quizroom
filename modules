/* Raccourcis clavier */
function _initKeyboardShortcuts() {
  document.addEventListener('keydown', e => {
    if (['INPUT','TEXTAREA','SELECT'].includes(document.activeElement?.tagName)) return;

    if (e.key === 'Escape') {
      document.querySelectorAll('.modal.open').forEach(m => m.classList.remove('open'));
      return;
    }

    if (e.ctrlKey || e.metaKey) {
      switch (e.key) {
        case 'n': e.preventDefault(); if (typeof handleNewButton === 'function') handleNewButton();  break;
        case 'k': e.preventDefault(); document.getElementById('global-search')?.focus();              break;
        case 'e': e.preventDefault(); if (typeof openComposeEmail === 'function') { navigate('email'); setTimeout(() => openComposeEmail({}), 300); } break;
        case 'p': e.preventDefault(); navigate('pipeline');    break;
        case 'd': e.preventDefault(); navigate('dashboard');   break;
      }
    }
  });
}

/* Appel guidé */
function startGuidedCall(contactId, contactName, dealId) {
  if (document.getElementById('call-overlay')) return;

  const overlay = document.createElement('div');
  overlay.id = 'call-overlay';
  overlay.className = 'call-overlay';
  overlay.innerHTML = `
    <div class="call-header">
      <span class="call-phone-icon"><i class="fa-solid fa-phone"></i></span>
      <span>Appel — ${_esc(contactName || 'Contact')}</span>
      <span class="call-timer" id="call-timer">00:00</span>
    </div>
    <textarea id="call-notes" placeholder="Notes pendant l'appel…" rows="3"></textarea>
    <div style="display:flex;gap:8px;flex-wrap:wrap">
      <button class="btn btn-secondary btn-sm" onclick="endCall(${contactId}, ${dealId || 'null'}, false)">
        <i class="fa-solid fa-xmark"></i> Raccroché
      </button>
      <button class="btn btn-primary btn-sm" onclick="endCall(${contactId}, ${dealId || 'null'}, true)">
        <i class="fa-solid fa-check"></i> Enregistrer l'appel
      </button>
    </div>`;

  document.body.appendChild(overlay);
  _callStartTime = Date.now();
  _callTimerInterval = setInterval(_tickCallTimer, 1000);
}

function _tickCallTimer() {
  const el = document.getElementById('call-timer');
  if (!el) { clearInterval(_callTimerInterval); return; }
  const s  = Math.floor((Date.now() - _callStartTime) / 1000);
  el.textContent = `${String(Math.floor(s/60)).padStart(2,'0')}:${String(s%60).padStart(2,'0')}`;
}

async function endCall(contactId, dealId, save) {
  clearInterval(_callTimerInterval);
  const notes = document.getElementById('call-notes')?.value?.trim() || '';
  const dur   = _callStartTime ? Math.floor((Date.now() - _callStartTime)/1000) : 0;

  document.getElementById('call-overlay')?.remove();

  if (save) {
    const durStr = `${Math.floor(dur/60)}min ${dur%60}s`;
    await logActivity({
      contact_id: contactId,
      deal_id:    dealId || null,
      type:       'call',
      title:      `Appel (${durStr})`,
      body:       notes,
      metadata:   { duration_seconds: dur },
    });
    showToast(`Appel enregistré (${durStr})`, 'success');
  }
}

