async function exportToCSV(table) {
  showLoader(`Export ${table}…`);
  try {
    const { data } = await _sb.from(table).select('*');
    if (!data?.length) { showToast('Aucune donnée à exporter', 'info'); hideLoader(); return; }
    const headers = Object.keys(data[0]).join(';');
    const rows    = data.map(row =>
      Object.values(row).map(v =>
        typeof v === 'object' ? JSON.stringify(v||'').replace(/;/g,'|')
        : String(v ?? '').replace(/;/g,'|')
      ).join(';')
    );
    const csv  = '\uFEFF' + [headers, ...rows].join('\n');
    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8' });
    const url  = URL.createObjectURL(blob);
    const a    = Object.assign(document.createElement('a'), { href: url, download: `crm_${table}_${today()}.csv` });
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
    URL.revokeObjectURL(url);
    showToast(`Export ${table} ✓`, 'success');
  } catch (e) { showToast('Erreur export : ' + e.message, 'error'); }
  finally { hideLoader(); }
}

async function _exportFullBackup() {
  showLoader('Backup…');
  try {
    const [deals, companies, contacts, quotes, activities] = await Promise.all([
      _sb.from('deals').select('*'), _sb.from('companies').select('*'),
      _sb.from('contacts').select('*'), _sb.from('quotes').select('*'),
      _sb.from('activities').select('*'),
    ]);
    const backup = { date: new Date().toISOString(), deals:deals.data, companies:companies.data, contacts:contacts.data, quotes:quotes.data, activities:activities.data };
    const blob   = new Blob([JSON.stringify(backup, null, 2)], { type: 'application/json' });
    const a      = Object.assign(document.createElement('a'), { href: URL.createObjectURL(blob), download: `crm_backup_${today()}.json` });
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
    showToast('Backup exporté ✓', 'success');
  } catch (e) { showToast('Erreur : ' + e.message, 'error'); }
  finally { hideLoader(); }
}

/* handleCSV alias (même que pipeline.js) */
function handleCSV(e) {
  const input = document.getElementById('csv-file-input') || e.target;
  if (e.target) {
    const evt = new Event('change');
    Object.defineProperty(evt, 'target', { value: e.target, writable: false });
    /* Appeler le handler CSV du pipeline via la bonne entrée */
    if (e.target.files?.[0]) {
      const file = e.target.files[0];
      showLoader(`Import de ${file.name}…`);
      file.text().then(async text => {
        try {
          const rows   = typeof _parseCSV === 'function' ? _parseCSV(text) : [];
          if (!rows.length) { showToast('Aucune ligne valide', 'warning'); hideLoader(); return; }
          const result = await importDealsFromCSV(rows);
          hideLoader();
          showToast(`Import : ${result.ok} deal(s)${result.errors?', '+result.errors+' erreur(s)':''}`,
            result.errors > 0 ? 'warning' : 'success');
        } catch (err) { hideLoader(); showToast('Erreur : ' + err.message, 'error'); }
      });
      e.target.value = '';
    }
  }
}

