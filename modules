}

function _injectAIError(msg) {
  const block = document.getElementById('ai-analysis-block');
  if (block) block.innerHTML = `
    <div class="ai-error">
      <i class="fa-solid fa-triangle-exclamation"></i>
      Analyse IA indisponible : ${msg}
