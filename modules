function _renderSection4Quotes(from) {
  const quotes = _analyticsQuotes.filter(q => (q.created_at||'').slice(0,10) >= from);

  const sent    = quotes.filter(q => q.status !== 'draft').length;
  const signed  = quotes.filter(q => q.status === 'signed').length;
  const refused = quotes.filter(q => q.status === 'refused').length;
  const negot   = quotes.filter(q => q.status === 'negotiating').length;
  const draft   = quotes.filter(q => q.status === 'draft').length;
  const rate    = sent > 0 ? Math.round(signed / sent * 100) : 0;

  const amounts = quotes.filter(q => q.total_ttc > 0);
  const avgAmt  = amounts.length > 0 ? Math.round(amounts.reduce((s,q)=>s+(Number(q.total_ttc)||0),0)/amounts.length) : 0;

  const signDelays = quotes
    .filter(q => q.status==='signed' && q.sent_at && q.signed_at)
    .map(q => _daysBetween(q.sent_at, q.signed_at));
  const avgDelay = signDelays.length > 0
    ? Math.round(signDelays.reduce((s,d)=>s+d,0)/signDelays.length)
