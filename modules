/* ────────────────────────────────────────────────────────────────
   CSV IMPORT
──────────────────────────────────────────────────────────────── */
function initCSVImport() {
  const input = document.getElementById('csv-file-input');
  if (!input || input._csvInited) return;
  input._csvInited = true;

  input.addEventListener('change', async e => {
    const file = e.target.files[0];
    if (!file) return;

    showLoader(`Import de ${file.name}…`);
    try {
      const text   = await file.text();
      const rows   = _parseCSV(text);
      if (rows.length === 0) { showToast('Aucune ligne valide dans le CSV', 'warning'); hideLoader(); return; }

      const result = await importDealsFromCSV(rows);
      hideLoader();
      showToast(
        `Import terminé : ${result.ok} deal(s) ajouté(s)${result.errors ? ', ' + result.errors + ' erreur(s)' : ''}`,
        result.errors > 0 ? 'warning' : 'success'
      );
      await renderPipeline();
    } catch (e) {
      hideLoader();
      showToast('Erreur import : ' + e.message, 'error');
    }
    input.value = '';
  });
}

function _parseCSV(text) {
  const lines = text.split('\n').map(l => l.trim()).filter(Boolean);
  if (lines.length < 2) return [];

  /* Détection séparateur */
  const sep = lines[0].includes(';') ? ';' : ',';
  const headers = lines[0].split(sep).map(h => h.replace(/^"|"$/g, '').trim().toLowerCase());

  const get = (obj, ...keys) => {
    for (const k of keys) if (obj[k] !== undefined && obj[k] !== '') return obj[k];
    return null;
  };

  return lines.slice(1).map(line => {
    const vals = line.split(sep).map(v => v.replace(/^"|"$/g, '').trim());
    const obj  = {};
    headers.forEach((h, i) => { obj[h] = vals[i] || ''; });
    return {
      title:        get(obj, 'title', 'nom', 'name')             || null,
      amount:       parseFloat(get(obj, 'amount', 'prix', 'montant') || 0) || 0,
      status:       get(obj, 'status', 'statut')                 || 'new',
      source:       get(obj, 'source')                           || 'csv',
      room_type:    get(obj, 'room_type', 'salle')               || null,
      nb_guests:    parseInt(get(obj, 'nb_guests', 'participants') || 0) || null,
      date_event:   get(obj, 'date_event', 'datee')              || null,
      date_relance: get(obj, 'date_relance', 'dater')            || null,
      date_created: get(obj, 'date_created', 'datec')            || null,
      infos:        get(obj, 'infos', 'notes')                   || null,
    };
  }).filter(r => r.title || r.amount > 0);
}

/* ────────────────────────────────────────────────────────────────
   LEAD SCORING — Phase 6
   Calcul des scores de priorité et mise à jour batch
──────────────────────────────────────────────────────────────── */
function computeLeadScore(company, deal) {
  let score = 50; // base

  /* Facteurs IA / prospection */
  if (company?.ai_score) score += (company.ai_score - 50) * 0.3;

  /* Événement imminent */
  if (deal?.date_event) {
    const dToEvent = daysUntil(deal.date_event);
    if (dToEvent >= 0 && dToEvent <= 7)  score += 30;
    else if (dToEvent >= 0 && dToEvent <= 30) score += 15;
  }

  /* Relance en retard = priorité haute */
  if (deal?.date_relance) {
    const dRelance = daysUntil(deal.date_relance);
    if (dRelance < 0)       score += 25;
    else if (dRelance === 0) score += 15;
    else if (dRelance <= 3)  score += 8;
  }

  /* Montant */
  const amt = Number(deal?.amount) || 0;
  if (amt > 1200) score += 15;
  else if (amt > 800) score += 10;
  else if (amt > 400) score += 5;

  /* Résistance aux relances */
  const rel = deal?.nb_relances || 0;
  if (rel === 0) score += 8;      // jamais contacté
  else if (rel > 5) score -= 15;  // résistant

  return Math.min(100, Math.max(0, Math.round(score)));
}

async function refreshLeadScores() {
  try {
    const [companies] = await Promise.all([fetchCompanies()]);
    const updates = [];
    for (const deal of _allDeals) {
      if (['won','lost'].includes(deal.status)) continue;
      const company  = companies.find(c => c.id === deal.company_id) || null;
      const newScore = computeLeadScore(company, deal);
      if (newScore !== deal.priority_score) {
        updates.push({ id: deal.id, score: newScore });
      }
    }
    /* Mise à jour batch silencieuse */
    for (const u of updates.slice(0, 20)) {
      await _sb.from('deals').update({ priority_score: u.score }).eq('id', u.id);
    }
    if (updates.length > 0) console.info(`[LeadScore] ${updates.length} scores mis à jour`);
  } catch (e) {
    console.warn('[refreshLeadScores]', e.message);
  }
}

