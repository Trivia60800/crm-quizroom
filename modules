/* ────────────────────────────────────────────────────────────────
   SYNC HOVER carte ↔ liste
──────────────────────────────────────────────────────────────── */
function _highlightCard(placeId) {
  document.querySelectorAll('.prosp-card').forEach(c => {
    c.classList.toggle('highlighted', c.dataset.placeId === placeId);
  });
  // Scroll la card dans le viewport
  const card = document.querySelector(`.prosp-card[data-place-id="${placeId}"]`);
  card?.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
}
function _unhighlightCard(placeId) {
  document.querySelector(`.prosp-card[data-place-id="${placeId}"]`)?.classList.remove('highlighted');
}
function _highlightMarker(placeId) {
  const m = prospMarkers.find(m => m.place_id === placeId);
  if (m) m.setAnimation(google.maps.Animation.BOUNCE);
}
function _unhighlightMarker(placeId) {
  const m = prospMarkers.find(m => m.place_id === placeId);
  if (m) m.setAnimation(null);
}

/* ────────────────────────────────────────────────────────────────
   FICHE DÉTAILLÉE — side panel
──────────────────────────────────────────────────────────────── */
async function openPlaceDetails(placeId) {
  // Ouvrir le panel avec loader
  _openSidePanel(`
    <div class="side-panel-header">
      <span class="side-panel-title">Fiche entreprise</span>
      <button class="modal-close" onclick="closePlacePanel()"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="side-panel-body">
      <div class="page-loading" style="min-height:200px">
        <div class="spinner"></div><p>Chargement…</p>
      </div>
    </div>`);

  // Détails Places
  const place = await _fetchPlaceDetails(placeId);
  if (!place) {
    _sideBodyHTML('<p style="color:var(--urgent);padding:24px">Impossible de charger cette fiche.</p>');
    return;
  }
  currentPlaceData = place;
  currentPlaceData.place_id = placeId;
  currentAIAnalysis = null;

  // Afficher infos de base immédiatement
  _renderPlacePanel(place, null, placeId);

  // Enrichissement IA en arrière-plan
  try {
    currentAIAnalysis = await enrichProspectWithAI(place);
    _injectAIAnalysis(currentAIAnalysis);
  } catch (e) {
    _injectAIError(e.message);
  }
}

function _fetchPlaceDetails(placeId) {
  return new Promise(resolve => {
    const service = new google.maps.places.PlacesService(prospMap);
    service.getDetails({
      placeId,
      fields: [
        'name','formatted_address','formatted_phone_number',
        'website','rating','user_ratings_total','opening_hours',
        'photos','types','geometry','business_status','url',
        'international_phone_number',
      ],
    }, (place, status) => {
      resolve(status === google.maps.places.PlacesServiceStatus.OK ? place : null);
    });
  });
}

function _renderPlacePanel(place, aiData, placeId) {
  const inCRM  = prospExistingIds.has(placeId);
  const photo  = place.photos?.[0]
    ? `<div class="place-photo" style="background-image:url('${place.photos[0].getUrl({ maxWidth: 520 })}')"></div>`
    : `<div class="place-photo place-photo-empty"><i class="fa-solid fa-building"></i></div>`;

  const hours = place.opening_hours?.weekday_text
    ? `<div class="place-hours">
        ${place.opening_hours.weekday_text.map(h => `<div class="place-hour-row">${h}</div>`).join('')}
       </div>`
    : '';

  const types = (place.types || [])
    .filter(t => !['point_of_interest','establishment'].includes(t))
    .map(t => t.replace(/_/g, ' '))
    .slice(0, 3);

  _sideBodyHTML(`
    ${photo}
    <div class="place-main-info">
      <h2 class="place-name">${place.name}</h2>
      ${types.map(t => `<span class="prosp-chip tag" style="margin-right:4px">${t}</span>`).join('')}
      <div class="place-meta-list">
        ${place.formatted_address   ? `<div class="place-meta-row"><i class="fa-solid fa-location-dot"></i><span>${place.formatted_address}</span></div>` : ''}
        ${place.formatted_phone_number ? `<div class="place-meta-row"><i class="fa-solid fa-phone"></i><a href="tel:${place.formatted_phone_number}">${place.formatted_phone_number}</a></div>` : ''}
        ${place.website             ? `<div class="place-meta-row"><i class="fa-solid fa-globe"></i><a href="${place.website}" target="_blank" rel="noopener">${_shortenUrl(place.website)}</a></div>` : ''}
        ${place.rating              ? `<div class="place-meta-row"><i class="fa-solid fa-star" style="color:#f59e0b"></i><span>${place.rating}/5 (${place.user_ratings_total || 0} avis)</span></div>` : ''}
        ${place.url                 ? `<div class="place-meta-row"><i class="fa-brands fa-google"></i><a href="${place.url}" target="_blank" rel="noopener">Voir sur Google Maps</a></div>` : ''}
      </div>
      ${hours ? `<details class="place-hours-details"><summary>Horaires</summary>${hours}</details>` : ''}
    </div>

    <!-- ANALYSE IA -->
    <div class="ai-analysis-block" id="ai-analysis-block">
      <div class="ai-loading">
        <div class="spinner" style="width:20px;height:20px;border-width:2px"></div>
        <span>Analyse IA en cours…</span>
      </div>
    </div>

    <!-- ACTIONS -->
    <div class="place-actions">
      <button class="btn btn-secondary" onclick="openScriptPanel(currentPlaceData,'email')" ${!aiData && 'id="btn-script-email"'}>
        <i class="fa-solid fa-wand-magic-sparkles"></i> Script Email
      </button>
      <button class="btn btn-secondary" onclick="openScriptPanel(currentPlaceData,'tel')">
        <i class="fa-solid fa-phone"></i> Script Tél
      </button>
      ${inCRM
        ? `<span class="already-in-crm large"><i class="fa-solid fa-check"></i> Dans le CRM</span>`
        : `<button class="btn btn-primary" onclick="addToCRMFromPanel()">
             <i class="fa-solid fa-plus"></i> Ajouter au CRM
           </button>`}
    </div>`);
}

function _injectAIAnalysis(ai) {
  const block = document.getElementById('ai-analysis-block');
  if (!block || !ai) { _injectAIError('Analyse indisponible'); return; }

  const score = ai.score_pertinence || 0;
  const scoreColor = score >= 70 ? 'var(--won)' : score >= 40 ? 'var(--warning)' : 'var(--muted)';

  block.innerHTML = `
    <div class="ai-analysis-inner">
      <div class="ai-badge"><i class="fa-solid fa-wand-magic-sparkles"></i> Analyse IA</div>

      <div class="ai-score-block">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px">
          <span class="ai-score-label">Score de pertinence</span>
          <span class="ai-score-value" style="color:${scoreColor}">${score}/100</span>
        </div>
        <div class="score-bar">
          <div class="score-fill" style="width:${score}%;background:${scoreColor}"></div>
        </div>
      </div>

      <div class="ai-grid">
        <div class="ai-row"><span class="ai-row-label">Potentiel</span><span>${ai.potentiel || '—'}</span></div>
        <div class="ai-row"><span class="ai-row-label">Type cible</span>
          <span class="prosp-chip tag">${ai.type_cible || '—'}</span>
        </div>
        <div class="ai-row"><span class="ai-row-label">Angle d'approche</span><span>${ai.angle_approche || '—'}</span></div>
        <div class="ai-row"><span class="ai-row-label">Contact idéal</span><span>${ai.meilleur_contact || '—'}</span></div>
        <div class="ai-row"><span class="ai-row-label">Budget estimé</span>
          <span style="font-weight:600;color:var(--accent)">${ai.budget_estime || '—'}</span>
        </div>
        ${ai.points_attention ? `<div class="ai-row ai-row-warn">
