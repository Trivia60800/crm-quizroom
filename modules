function _loadGoogleMapsSDK(callback) {
  if (window.google?.maps) { callback(); return; }

  const key = CONFIG?.GOOGLE_MAPS_KEY;
  if (!key || key === 'VOTRE_CLE_GOOGLE_MAPS_ICI') {
    document.getElementById('prosp-map').innerHTML = `
      <div class="prosp-api-warn">
        <i class="fa-solid fa-triangle-exclamation"></i>
        <strong>Clé Google Maps non configurée</strong>
        <p>Renseignez <code>GOOGLE_MAPS_KEY</code> dans <code>utils/config.js</code>.</p>
      </div>`;
    return;
  }

  // Callback global nécessaire par l'API Google
  window._gmapsCB = callback;
  const script = document.createElement('script');
  script.src = `https://maps.googleapis.com/maps/api/js?key=${key}&libraries=places&callback=_gmapsCB&language=fr&region=FR`;
  script.async = true;
  script.onerror = () => {
    document.getElementById('prosp-map').innerHTML = `
      <div class="prosp-api-warn">
        <i class="fa-solid fa-triangle-exclamation"></i>
        <strong>Erreur de chargement Google Maps</strong>
