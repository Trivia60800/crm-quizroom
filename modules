function _initials(name) {
  if (!name) return '?';
  return name.split(/\s+/).slice(0, 2).map(w => w[0]?.toUpperCase() || '').join('');
}

function _distanceKm(a, b) {
  const R   = 6371;
  const dLat = (b.lat - a.lat) * Math.PI / 180;
  const dLng = (b.lng - a.lng) * Math.PI / 180;
  const x   = Math.sin(dLat/2) ** 2 +
              Math.cos(a.lat * Math.PI / 180) * Math.cos(b.lat * Math.PI / 180) *
              Math.sin(dLng/2) ** 2;
  return (R * 2 * Math.atan2(Math.sqrt(x), Math.sqrt(1-x))).toFixed(1);
}

function _extractCity(address) {
  if (!address) return null;
  // Cherche un code postal puis la ville : "80000 Amiens"
  const m = address.match(/\b\d{5}\s+([^,]+)/);
  if (m) return m[1].trim();
  // Sinon dernier token avant "France"
  const parts = address.split(',').map(s => s.trim());
  const fr = parts.findIndex(p => /france/i.test(p));
  if (fr > 0) return parts[fr - 1];
  return parts[1] || null;
}

function _shortenUrl(url) {
  return url.replace(/^https?:\/\/(www\.)?/, '').replace(/\/$/, '').substring(0, 40);
}

