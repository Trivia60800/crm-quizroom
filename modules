/* ────────────────────────────────────────────────────────────────
   BROUILLON LOCAL
──────────────────────────────────────────────────────────────── */
function saveDraftLocally() {
  _savedDraft = {
    to:          [..._composeTo],
    cc:          document.getElementById('compose-cc')?.value      || '',
    subject:     document.getElementById('compose-subject')?.value || '',
    body:        document.getElementById('compose-body')?.innerHTML || '',
    attachments: [..._currentAttachments],
  };
  showToast('Brouillon sauvegardé localement', 'success');
}

function _restoreDraft() {
  if (!_savedDraft) return;
  _composeTo          = _savedDraft.to;
  _currentAttachments = _savedDraft.attachments;
  const cc  = document.getElementById('compose-cc');
  const sub = document.getElementById('compose-subject');
  const bod = document.getElementById('compose-body');
  if (cc)  cc.value           = _savedDraft.cc;
  if (sub) sub.value          = _savedDraft.subject;
  if (bod) bod.innerHTML      = _savedDraft.body;
  _renderRecipients();
  _renderAttachments();
  showToast('Brouillon restauré', 'info');
}

function _resetComposeForm() {
  _composeTo          = [];
  _currentAttachments = [];
  _composeContext     = null;
  const ids = ['compose-cc','compose-subject'];
  ids.forEach(id => { const el = document.getElementById(id); if (el) el.value = ''; });
  const body = document.getElementById('compose-body');
  if (body) body.innerHTML = '';
  _renderRecipients();
  _renderAttachments();
}

/* ────────────────────────────────────────────────────────────────
   ENVOI
──────────────────────────────────────────────────────────────── */
async function sendEmail() {
  const to      = _composeTo.map(r => r.email).filter(Boolean);
  const cc      = document.getElementById('compose-cc')?.value?.trim() || '';
  const subject = document.getElementById('compose-subject')?.value?.trim() || '';
  const bodyEl  = document.getElementById('compose-body');
  const htmlBody = bodyEl?.innerHTML || '';
  const sigEl   = document.getElementById('compose-signature');

  if (!to.length) { showToast('Ajoutez au moins un destinataire', 'error'); return; }
  if (!subject)   { showToast('L\'objet est obligatoire', 'error'); return; }
  if (!htmlBody || htmlBody === '<br>') {
    showToast('Le corps de l\'email est vide', 'error'); return;
  }

  const btn = document.querySelector('.compose-footer .btn-primary');
  if (btn) { btn.disabled = true; btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Envoi…'; }

  try {
    const fullHtml = buildEmailHTML(htmlBody, sigEl?.querySelector('.sig-body')?.innerHTML || '');

    const result = await gmailSend({
      to:          to.join(', '),
      cc,
      subject,
      htmlBody:    fullHtml,
      attachments: _currentAttachments,
    });

    /* Logger dans activities */
    const ctx = _composeContext || {};
    await logActivity({
      company_id: ctx.company_id || null,
      contact_id: ctx.contact_id || null,
      deal_id:    ctx.deal_id    || null,
      type:       'email',
      title:      subject,
      body:       (bodyEl?.innerText || '').substring(0, 300),
      metadata:   {
        gmail_message_id: result.id,
        to,
        cc:          cc || null,
        attachments: _currentAttachments.map(a => a.name),
      },
    });

    showToast('Email envoyé ✓', 'success');
    _resetComposeForm();
    await _loadEmailHistory();

  } catch (e) {
    showToast('Erreur envoi : ' + e.message, 'error');
  } finally {
    if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fa-solid fa-paper-plane"></i> Envoyer'; }
  }
}

