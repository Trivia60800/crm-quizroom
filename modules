──────────────────────────────────────────────────────────────── */
function _placeMarkers(places, append = false) {
  if (!append) _clearMarkers();

  places.forEach(place => {
    if (!place.geometry?.location) return;

    const inCRM  = prospExistingIds.has(place.place_id);
    const marker = new google.maps.Marker({
      map:      prospMap,
      position: place.geometry.location,
      title:    place.name,
      icon: {
        path: google.maps.SymbolPath.CIRCLE,
        scale:       8,
        fillColor:   inCRM ? '#16a34a' : '#5b4cf0',
        fillOpacity: 0.9,
        strokeColor: '#ffffff',
        strokeWeight: 2,
      },
    });

    marker.place_id = place.place_id;

    marker.addListener('click', () => {
      _highlightCard(place.place_id);
      _openInfoWindow(marker, place);
    });

    marker.addListener('mouseover', () => _highlightCard(place.place_id));
    marker.addListener('mouseout',  () => _unhighlightCard(place.place_id));

    prospMarkers.push(marker);
  });
}

function _clearMarkers() {
  prospMarkers.forEach(m => m.setMap(null));
  prospMarkers = [];
}

function _openInfoWindow(marker, place) {
