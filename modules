function _getPeriodFrom(days) {
  const d = new Date();
  d.setDate(d.getDate() - days);
  return d.toISOString().split('T')[0];
}

function _setAnalyticsPeriod(days) {
  _analyticsPeriod = days;
  _destroyAllCharts();
  const from = _getPeriodFrom(days);
  document.getElementById('analytics-from').value = from;
  document.querySelectorAll('.period-btn').forEach(b => b.classList.toggle('active', parseInt(b.dataset.period) === days));
  _renderSection1Revenue(from);
  _renderSection2Pipeline(from);
  _renderSection3Relances(from);
  _renderSection4Quotes(from);
  _renderSection5Sources(from);
}

function _setCustomPeriod() {
  document.querySelectorAll('.period-btn').forEach(b => b.classList.remove('active'));
  const from = document.getElementById('analytics-from')?.value || _getPeriodFrom(30);
  _destroyAllCharts();
  _renderSection1Revenue(from);
  _renderSection2Pipeline(from);
  _renderSection3Relances(from);
  _renderSection4Quotes(from);
  _renderSection5Sources(from);
}

/* ────────────────────────────────────────────────────────────────
   SECTION 1 — REVENUS
──────────────────────────────────────────────────────────────── */
function _renderSection1Revenue(from) {
  const won = _analyticsDeals.filter(d =>
    d.status === 'won' && (d.updated_at || d.created_at || '').slice(0, 10) >= from
  );

  const total = won.reduce((s, d) => s + (Number(d.amount) || 0), 0);
  const avg   = won.length > 0 ? Math.round(total / won.length) : 0;
  const best  = won.length > 0 ? won.reduce((max, d) => Number(d.amount) > Number(max.amount || 0) ? d : max, won[0]) : null;

  _setEl('astat-total-ca',   _fmtE(total));
  _setEl('astat-avg-deal',   _fmtE(avg));
  _setEl('astat-won-count',  `${won.length} deal${won.length !== 1 ? 's' : ''}`);
  _setEl('astat-best-deal',  best ? `${_esc(best.title || best.companies?.name || '—')}<br><small>${_fmtE(best.amount)}</small>` : '—');

  /* Bar chart mensuel */
  const canvas = document.getElementById('analytics-revenue-chart');
  if (!canvas || typeof Chart === 'undefined') return;

  const months = _getMonthRange(from);
  const data   = months.map(m =>
    won.filter(d => (d.updated_at || d.created_at || '').slice(0, 7) === m.key)
       .reduce((s, d) => s + (Number(d.amount) || 0), 0)
  );

  _analyticsCharts['revenue'] = new Chart(canvas, {
    type: 'bar',
    data: {
      labels: months.map(m => m.label),
      datasets: [{
        label: 'CA (€)', data,
        backgroundColor: 'rgba(91,76,240,0.65)',
        borderRadius: 7, borderSkipped: false, borderWidth: 0,
      }],
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false }, tooltip: { callbacks: { label: c => '  ' + _fmtE(c.raw) } } },
      scales: {
        y: { beginAtZero: true, ticks: { callback: v => v === 0 ? '0' : (v/1000).toFixed(0)+'k €', font:{size:11}, color:'#9a9690' }, grid: { color: '#e8e6e1' } },
        x: { grid: { display: false }, ticks: { font:{size:11}, color:'#9a9690' } },
      },
    },
  });
}

/* ────────────────────────────────────────────────────────────────
   SECTION 2 — PIPELINE HEALTH
──────────────────────────────────────────────────────────────── */
function _renderSection2Pipeline(from) {
  const inPeriod  = _analyticsDeals.filter(d => (d.created_at||'').slice(0,10) >= from);
  const total     = inPeriod.length;
  const won       = inPeriod.filter(d => d.status === 'won').length;
  const lost      = inPeriod.filter(d => d.status === 'lost').length;
  const closed    = won + lost;
  const txConv    = closed > 0 ? Math.round(won / closed * 100) : 0;

  /* Stacked bar par statut */
  const stageCanvas = document.getElementById('analytics-stage-chart');
  const statusCounts = ['new','progress','urgent','won','lost']
    .map(s => ({ label: {new:'Nouveau',progress:'En cours',urgent:'Relance',won:'Gagné',lost:'Perdu'}[s], count: _analyticsDeals.filter(d=>d.status===s).length }));

  if (stageCanvas && typeof Chart !== 'undefined') {
    _analyticsCharts['stage'] = new Chart(stageCanvas, {
      type: 'bar',
      data: {
        labels: statusCounts.map(s => s.label),
        datasets: [{
          data: statusCounts.map(s => s.count),
          backgroundColor: ['#5b4cf0','#0284c7','#dc2626','#16a34a','#9a9690'],
          borderRadius: 6, borderWidth: 0,
        }],
      },
      options: {
        responsive: true, maintainAspectRatio: false, indexAxis: 'y',
        plugins: { legend: { display: false } },
        scales: { x: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: '#e8e6e1' } }, y: { grid: { display: false } } },
      },
    });
  }

  /* Doughnut conversion */
  const convCanvas = document.getElementById('analytics-conversion-chart');
  if (convCanvas && typeof Chart !== 'undefined' && closed > 0) {
    _analyticsCharts['conv'] = new Chart(convCanvas, {
      type: 'doughnut',
      data: {
        labels: ['Gagnés', 'Perdus', 'En cours'],
        datasets: [{
          data: [won, lost, total - closed],
          backgroundColor: ['#16a34a','#dc2626','#9a9690'],
          borderWidth: 0, hoverOffset: 4,
        }],
      },
      options: {
        responsive: true, maintainAspectRatio: false, cutout: '65%',
        plugins: {
          legend: { position: 'bottom', labels: { usePointStyle: true, padding: 10, font: { size: 11 } } },
          tooltip: { callbacks: { label: c => ` ${c.label} : ${c.raw} (${Math.round(c.raw/total*100)}%)` } },
        },
      },
    });
  } else if (convCanvas) {
    convCanvas.closest('.analytics-chart-card').querySelector('.chart-card-header').insertAdjacentHTML(
      'afterend', '<div class="empty-state-sm" style="padding:40px 0">Pas encore de données</div>'
    );
  }

  /* Bottleneck: deals bloqués > 21j sans activité */
  const stuck = _analyticsDeals.filter(d =>
    ['new','progress'].includes(d.status) &&
    _daysSince(d.updated_at || d.created_at) > 21
  );
  const alertEl = document.getElementById('bottleneck-alert');
  const textEl  = document.getElementById('bottleneck-text');
