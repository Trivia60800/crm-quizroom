    const actsMonth = _analyticsActivities.filter(a => (a.created_at||'').slice(0,10) >= from);
    const dealsMonth = _analyticsDeals.filter(d => (d.created_at||'').slice(0,10) >= from);
    const quotesMonth= _analyticsQuotes.filter(q => (q.created_at||'').slice(0,10) >= from);

    const caGagne        = dealsMonth.filter(d=>d.status==='won').reduce((s,d)=>s+(Number(d.amount)||0),0);
    const dealsActifs    = _analyticsDeals.filter(d=>['new','progress','urgent'].includes(d.status)).length;
    const devisEnvoyes   = quotesMonth.filter(q=>q.status!=='draft').length;
    const devisSignes    = quotesMonth.filter(q=>q.status==='signed').length;
    const tauxDevis      = devisEnvoyes>0 ? Math.round(devisSignes/devisEnvoyes*100) : 0;
    const emailsEnvoyes  = actsMonth.filter(a=>a.type==='email').length;
    const relancesFaites = actsMonth.filter(a=>['relance','call'].includes(a.type)).length;
    const totalCRMcos    = _analyticsCompanies.length;

    const report = await generateMonthlyAIReport({
      caGagne, dealsActifs, devisEnvoyes, devisSignes, tauxDevis,
      emailsEnvoyes, relancesFaites, totalCRMcos,
    });

    const mois = new Date().toLocaleDateString('fr-FR', { month: 'long', year: 'numeric' });
    card.innerHTML = `
      <div class="ai-report-header">
        <i class="fa-solid fa-wand-magic-sparkles"></i>
