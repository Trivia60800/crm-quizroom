──────────────────────────────────────────────────────────────── */
function _updateRadiusCircle(center, radiusKm) {
  if (prospRadiusCircle) prospRadiusCircle.setMap(null);
  prospRadiusCircle = new google.maps.Circle({
    map: prospMap,
    center,
    radius: radiusKm * 1000,
    strokeColor: '#5b4cf0',
    strokeOpacity: 0.35,
    strokeWeight: 2,
    fillColor: '#5b4cf0',
    fillOpacity: 0.04,
  });
  prospMap.fitBounds(prospRadiusCircle.getBounds());
}

/* ────────────────────────────────────────────────────────────────
   GEOCODER UNE ADRESSE
──────────────────────────────────────────────────────────────── */
function _geocodeAddress(address) {
  return new Promise(resolve => {
    const geocoder = new google.maps.Geocoder();
    geocoder.geocode({ address, region: 'fr' }, (results, status) => {
      if (status === 'OK' && results[0]) {
        resolve(results[0].geometry.location);
      } else {
        resolve(null);
      }
    });
  });
}

/* ────────────────────────────────────────────────────────────────
   SEARCH PLACES
──────────────────────────────────────────────────────────────── */
function _nearbySearch(center, radiusMeters, keyword) {
  return new Promise(resolve => {
    const service = new google.maps.places.PlacesService(prospMap);
    const req = {
      location: center,
      radius: Math.min(radiusMeters, 50000), // Places API max 50km
      keyword: keyword || 'entreprise',
    };
    service.nearbySearch(req, (results, status, pagination) => {
      if (status === google.maps.places.PlacesServiceStatus.OK ||
          status === google.maps.places.PlacesServiceStatus.ZERO_RESULTS) {
        resolve({ results: results || [], pagination });
      } else {
        console.warn('[Places nearbySearch]', status);
        resolve({ results: [], pagination: null });
      }
    });
  });
}

/* ────────────────────────────────────────────────────────────────
   LANCER LA RECHERCHE
──────────────────────────────────────────────────────────────── */
async function launchProspSearch() {
  if (!prospMap) { showToast('Carte non initialisée', 'error'); return; }

  const query    = document.getElementById('prosp-query')?.value.trim() || 'Amiens';
  const radiusKm = parseInt(document.getElementById('prosp-radius')?.value) || 25;
  const sector   = document.getElementById('prosp-sector')?.value || '';
  const btn      = document.getElementById('btn-prosp-search');

  if (btn) { btn.disabled = true; btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Recherche…'; }
  _setProspStats('<i class="fa-solid fa-spinner fa-spin"></i> Localisation en cours…');
  _clearMarkers();
  prospResults = [];

  try {
    // 1. Géocoder la ville
    const latLng = await _geocodeAddress(query + ', France');
    if (!latLng) {
      _setProspStats('❌ Adresse introuvable. Essayez "Amiens" ou "Amiens, 80000".');
      return;
    }
    prospCenter = { lat: latLng.lat(), lng: latLng.lng() };
    prospMap.setCenter(prospCenter);

    // 2. Mettre à jour le cercle
    _updateRadiusCircle({ lat: latLng.lat(), lng: latLng.lng() }, radiusKm);

    // 3. Recherche Places
    const keyword = sector || 'entreprise société';
    const { results, pagination } = await _nearbySearch(latLng, radiusKm * 1000, keyword);

    prospResults   = results;
    prospPagination = pagination;

    _renderResults(results, false);
    _placeMarkers(results);

  } catch (e) {
    console.error('[launchProspSearch]', e);
    _setProspStats('❌ Erreur : ' + e.message);
    showToast('Erreur recherche : ' + e.message, 'error');
  } finally {
    if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fa-solid fa-magnifying-glass"></i> Rechercher'; }
  }
}

