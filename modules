'use strict';
/* ================================================================
   modules/pipeline.js — Quiz Room CRM
   Kanban deals : Nouveau | En cours | À relancer | Gagné | Perdu
   - Drag & drop SortableJS
   - Tags Salle + Source + alerte capacité
   - Modal add/edit avec sélection ROOMS + validation temps réel
   - Totaux par colonne
================================================================ */

/* ────────────────────────────────────────────────────────────────
   CONFIG COLONNES
──────────────────────────────────────────────────────────────── */
const PIPELINE_COLS = [
  { key: 'new',      label: 'Nouveau',    icon: 'fa-circle-dot',    colorVar: '--new',      cls: 'col-new'      },
  { key: 'progress', label: 'En cours',   icon: 'fa-arrows-rotate', colorVar: '--progress', cls: 'col-progress' },
  { key: 'urgent',   label: 'À relancer', icon: 'fa-bell',          colorVar: '--urgent',   cls: 'col-urgent'   },
  { key: 'won',      label: 'Gagné',      icon: 'fa-circle-check',  colorVar: '--won',      cls: 'col-won'      },
  { key: 'lost',     label: 'Perdu',      icon: 'fa-circle-xmark',  colorVar: '--lost',     cls: 'col-lost'     },
];

const SOURCE_LABELS = {
  prospection: { text: 'Prospection', icon: 'fa-magnifying-glass-location' },
  csv:         { text: 'Import CSV',  icon: 'fa-file-arrow-up'             },
  entrant:     { text: 'Entrant',     icon: 'fa-inbox'                     },
  manual:      { text: 'Manuel',      icon: 'fa-pen'                       },
};

/* ────────────────────────────────────────────────────────────────
   STATE
──────────────────────────────────────────────────────────────── */
let _allDeals            = [];
let _allCompanies        = [];
let _editingDealId       = null;
let _pipelineSearchQuery = '';
let _activeFilter        = 'all';

/* ────────────────────────────────────────────────────────────────
   PRIORITY & RELANCE HELPERS
──────────────────────────────────────────────────────────────── */
function computePriorityScore(deal) {
  let score = 0;
  if (deal.date_relance) {
    const d = daysUntil(deal.date_relance);
    if (d < 0)       score += 60;
    else if (d === 0) score += 40;
    else if (d <= 2)  score += 25;
    else if (d <= 7)  score += 12;
  }
  const amt = Number(deal.amount) || 0;
  if (amt > 5000)      score += 15;
  else if (amt > 2000) score += 8;
  else if (amt > 500)  score += 3;
  score += Math.min((deal.nb_relances || 0) * 3, 18);
  return score;
}

function getRelanceLabel(deal) {
  if (!deal.date_relance) return null;
  const d = daysUntil(deal.date_relance);
  if (d < 0)       return { text: `Retard ${Math.abs(d)}j`,  cls: 'rl-urgent'  };
  if (d === 0)     return { text: "Aujourd'hui",             cls: 'rl-urgent'  };
  if (d === 1)     return { text: 'Demain',                  cls: 'rl-warning' };
  if (d <= 7)      return { text: `Dans ${d}j`,              cls: 'rl-soon'    };
  return              { text: formatDateShort(deal.date_relance), cls: 'rl-future'  };
}

/* ────────────────────────────────────────────────────────────────
   CARD BUILDER
──────────────────────────────────────────────────────────────── */
function _buildDealCard(deal) {
  const companyName = deal.companies?.name ?? '—';
  const title       = deal.title || companyName;

  /* Room tag */
  let roomTag = '';
  if (deal.room_type && ROOMS?.[deal.room_type]) {
    const room   = ROOMS[deal.room_type];
    const colors = { quiz: 'var(--accent)', karaoke: 'var(--progress)', full: 'var(--warning)' };
    const col    = colors[room.type] || 'var(--muted)';
    roomTag = `<span class="deal-tag" style="background:${col}18;color:${col};border-color:${col}35">
      <i class="fa-solid ${room.type === 'karaoke' ? 'fa-microphone' : room.type === 'full' ? 'fa-star' : 'fa-gamepad'}"></i>
      ${room.label}
    </span>`;
  }

  /* Source tag */
  let sourceTag = '';
  if (deal.source && SOURCE_LABELS[deal.source]) {
    const s = SOURCE_LABELS[deal.source];
    sourceTag = `<span class="deal-tag deal-tag-source">
      <i class="fa-solid ${s.icon}"></i>${s.text}
    </span>`;
  }

  /* Capacity */
  let guestBadge = '';
  if (deal.nb_guests != null && deal.room_type) {
    const warn = validateRoomCapacity(deal.room_type, deal.nb_guests);
    if (warn) {
      guestBadge = `<span class="capacity-alert" title="${warn}">
        <i class="fa-solid fa-triangle-exclamation"></i> ${deal.nb_guests} pers.
      </span>`;
    } else {
      guestBadge = `<span class="guest-count">
        <i class="fa-solid fa-users"></i> ${deal.nb_guests}
      </span>`;
    }
  }

  /* Relance badge */
  let relanceBadge = '';
  if (!['won','lost'].includes(deal.status)) {
    const rl = getRelanceLabel(deal);
    if (rl) {
      relanceBadge = `<div class="card-relance ${rl.cls}">
        <i class="fa-solid fa-clock"></i> ${rl.text}
        ${deal.nb_relances ? `<span class="relance-count">${deal.nb_relances}×</span>` : ''}
      </div>`;
    }
  }

  /* Date event */
  let eventBadge = '';
  if (deal.date_event) {
    eventBadge = `<span class="card-event"><i class="fa-regular fa-calendar"></i> ${formatDate(deal.date_event)}</span>`;
  }

  /* Amount */
  const amountHTML = deal.amount
    ? `<div class="card-amount">${formatAmount(deal.amount)}</div>`
    : '';

  return `
    <div class="deal-card" data-id="${deal.id}" data-status="${deal.status}">
      <div class="card-top">
        <div class="card-title" title="${title}">${title}</div>
        <div class="card-btns">
          <button class="card-btn" onclick="openEditDeal(${deal.id})" title="Modifier">
            <i class="fa-solid fa-pen"></i>
          </button>
          <button class="card-btn danger" onclick="confirmDeleteDealUI(${deal.id})" title="Supprimer">
            <i class="fa-solid fa-trash"></i>
          </button>
        </div>
      </div>
      ${companyName !== title ? `<div class="card-company"><i class="fa-regular fa-building"></i> ${companyName}</div>` : ''}
      <div class="card-tags">${roomTag}${sourceTag}</div>
      <div class="card-footer">
        <div class="card-meta">${guestBadge}${eventBadge}</div>
        ${amountHTML}
      </div>
      ${relanceBadge}
      ${deal.priority_score > 0 ? '<div class="lead-score-mini" title="Score : ' + deal.priority_score + '/100"><div class="lead-score-bar"><div class="lead-score-fill" style="width:' + deal.priority_score + '%;background:' + (deal.priority_score >= 70 ? 'var(--won)' : deal.priority_score >= 40 ? 'var(--warning)' : 'var(--muted)') + '"></div></div><span style="color:' + (deal.priority_score >= 70 ? 'var(--won)' : deal.priority_score >= 40 ? 'var(--warning)' : 'var(--muted)') + ';font-size:10px;font-weight:700">' + deal.priority_score + '</span></div>' : ''}
    </div>`;
}

/* ────────────────────────────────────────────────────────────────
   KANBAN HTML
──────────────────────────────────────────────────────────────── */
function _buildKanbanHTML(deals) {
  return PIPELINE_COLS.map(col => {
    let colDeals = deals.filter(d => d.status === col.key);
    if (col.key === 'urgent') {
      colDeals = [...colDeals].sort((a, b) => computePriorityScore(b) - computePriorityScore(a));
    }
    const total   = colDeals.reduce((s, d) => s + (Number(d.amount) || 0), 0);
    const cards   = colDeals.map(_buildDealCard).join('');
    const isEmpty = colDeals.length === 0;

    return `
      <div class="pipeline-col ${col.cls}" data-status="${col.key}">
        <div class="col-head">
          <div class="col-head-left">
            <span class="col-dot" style="background:var(${col.colorVar})"></span>
            <i class="fa-solid ${col.icon}" style="color:var(${col.colorVar})"></i>
            <span class="col-label">${col.label}</span>
          </div>
          <span class="col-count" style="background:var(${col.colorVar})18;color:var(${col.colorVar})">${colDeals.length}</span>
        </div>
        <div class="col-cards" id="col-cards-${col.key}">
          ${isEmpty ? `<div class="col-empty"><i class="fa-solid fa-inbox"></i><span>Aucun deal</span></div>` : cards}
        </div>
        <div class="col-total">${total > 0 ? `<i class="fa-solid fa-coins"></i> ${formatAmount(total)}` : ''}</div>
      </div>`;
  }).join('');
}

/* ────────────────────────────────────────────────────────────────
   RENDER PIPELINE (entry point appelé par le router)
──────────────────────────────────────────────────────────────── */
async function renderPipeline() {
  const content = document.getElementById('app-content');
  if (!content) return;

  content.innerHTML = `
    <div class="page-loading">
      <div class="spinner"></div>
      <p>Chargement du pipeline…</p>
    </div>`;

  [_allDeals, _allCompanies] = await Promise.all([fetchDeals(), fetchCompanies()]);
  _rebuildPipeline();
}

function _rebuildPipeline() {
  const content = document.getElementById('app-content');
  if (!content) return;

  /* Filtrage texte */
  const q = _pipelineSearchQuery;
  let deals = q
    ? _allDeals.filter(d =>
        (d.title              || '').toLowerCase().includes(q) ||
        (d.companies?.name    || '').toLowerCase().includes(q) ||
        (d.source             || '').toLowerCase().includes(q) ||
        (d.infos              || '').toLowerCase().includes(q))
    : _allDeals;

  /* Filtrage type salle */
  if (_activeFilter !== 'all') {
    deals = deals.filter(d => d.room_type && ROOMS?.[d.room_type]?.type === _activeFilter);
  }

  const totalPipeline = _allDeals
    .filter(d => ['new','progress','urgent'].includes(d.status))
    .reduce((s, d) => s + (Number(d.amount) || 0), 0);

  content.innerHTML = `
    <div class="pipeline-toolbar">
      <div class="pipeline-filters">
        <button class="filter-btn ${_activeFilter==='all'?'active':''}"       data-filter="all">Tous <span>${_allDeals.length}</span></button>
        <button class="filter-btn ${_activeFilter==='quiz'?'active':''}"      data-filter="quiz"><i class="fa-solid fa-gamepad"></i> Quiz</button>
        <button class="filter-btn ${_activeFilter==='karaoke'?'active':''}"   data-filter="karaoke"><i class="fa-solid fa-microphone"></i> Karaoké</button>
        <button class="filter-btn ${_activeFilter==='full'?'active':''}"      data-filter="full"><i class="fa-solid fa-star"></i> Privatisation</button>
      </div>
      <div class="pipeline-summary">
        <span class="summary-chip"><i class="fa-solid fa-chart-simple"></i> Pipeline actif : <strong>${formatAmount(totalPipeline)}</strong></span>
        <label class="csv-label" title="Importer un fichier CSV">
          <i class="fa-solid fa-file-arrow-up"></i> Import CSV
          <input type="file" id="csv-file-input" accept=".csv" style="display:none">
        </label>
      </div>
    </div>
    <div class="pipeline-board" id="pipeline-board">
      ${_buildKanbanHTML(deals)}
    </div>`;

  _initSortable();
  initCSVImport();

  /* Filtre buttons */
  content.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      _activeFilter = btn.dataset.filter;
      _rebuildPipeline();
    });
  });
}

/* ────────────────────────────────────────────────────────────────
   SORTABLE
──────────────────────────────────────────────────────────────── */
function _initSortable() {
  if (typeof Sortable === 'undefined') {
    console.warn('SortableJS not loaded');
    return;
  }
  PIPELINE_COLS.forEach(col => {
    const el = document.getElementById(`col-cards-${col.key}`);
    if (!el || el._sortableInited) return;
    el._sortableInited = true;

    new Sortable(el, {
      group:      'pipeline',
      animation:  180,
      ghostClass: 'sortable-ghost',
      dragClass:  'sortable-drag',
      filter:     '.col-empty',
      onEnd: async evt => {
        const cardId    = parseInt(evt.item.dataset.id);
        const newStatus = evt.to.closest('.pipeline-col')?.dataset.status;
        const oldStatus = evt.from.closest('.pipeline-col')?.dataset.status;
        if (!newStatus || newStatus === oldStatus) return;

        evt.item.dataset.status = newStatus;

        /* Optimistic update */
        const deal = _allDeals.find(d => d.id === cardId);
        if (deal) deal.status = newStatus;
        _refreshColMeta();

        try {
          await updateDeal(cardId, { status: newStatus });
          await updateGlobalKPIs();
          const colLabel = PIPELINE_COLS.find(c => c.key === newStatus)?.label || newStatus;
          showToast(`Déplacé vers « ${colLabel} »`, 'success');
          await logActivity({ deal_id: cardId, type: 'status_change', title: `Statut → ${newStatus}` });
        } catch (e) {
          showToast('Erreur lors du déplacement', 'error');
          /* Rollback */
          if (deal) deal.status = oldStatus;
          _rebuildPipeline();
        }
      }
    });
  });
}

function _refreshColMeta() {
  PIPELINE_COLS.forEach(col => {
    const colEl  = document.querySelector(`.pipeline-col[data-status="${col.key}"]`);
    if (!colEl) return;
    const colDeals = _allDeals.filter(d => d.status === col.key);
    const total    = colDeals.reduce((s, d) => s + (Number(d.amount) || 0), 0);
    const countEl  = colEl.querySelector('.col-count');
    const totalEl  = colEl.querySelector('.col-total');
    if (countEl) countEl.textContent = colDeals.length;
    if (totalEl) totalEl.innerHTML   = total > 0 ? `<i class="fa-solid fa-coins"></i> ${formatAmount(total)}` : '';
  });
}

/* ────────────────────────────────────────────────────────────────
   MODAL ADD / EDIT DEAL
──────────────────────────────────────────────────────────────── */
function openAddModal(defaultStatus = 'new') {
  _editingDealId = null;
  document.getElementById('modal-deal-title').textContent = 'Nouveau deal';
  document.getElementById('btn-delete-deal').style.display = 'none';
  clearForm('form-deal');
  _populateDealSelects();
  // Pre-select status
  const statusSel = document.querySelector('#form-deal [name="status"]');
  if (statusSel) statusSel.value = defaultStatus;
  _toggleLostReason(defaultStatus);
  _liveCapacityCheck();
  openModal('modal-deal');
}

function openEditDeal(id) {
  const deal = _allDeals.find(d => d.id === id);
  if (!deal) { showToast('Deal introuvable', 'error'); return; }

  _editingDealId = id;
  document.getElementById('modal-deal-title').textContent = 'Modifier le deal';
  document.getElementById('btn-delete-deal').style.display = '';

  _populateDealSelects();

  setFormData('form-deal', {
    title:        deal.title        || '',
    company_id:   deal.company_id   || '',
    amount:       deal.amount       || '',
    status:       deal.status       || 'new',
    room_type:    deal.room_type    || '',
    nb_guests:    deal.nb_guests    || '',
    date_event:   deal.date_event   || '',
    date_relance: deal.date_relance || '',
    source:       deal.source       || '',
    infos:        deal.infos        || '',
    lost_reason:  deal.lost_reason  || '',
  });

  _toggleLostReason(deal.status);
  _liveCapacityCheck();
  openModal('modal-deal');
}

function _populateDealSelects() {
  /* Entreprises */
  const selCo = document.getElementById('deal-company-select');
  if (selCo) {
    selCo.innerHTML = '<option value="">— Entreprise (optionnel) —</option>' +
      _allCompanies.map(c => `<option value="${c.id}">${c.name}</option>`).join('');
  }

  /* Salles */
  const selRoom = document.getElementById('deal-room-select');
  if (selRoom && typeof ROOMS !== 'undefined') {
    selRoom.innerHTML = '<option value="">— Salle / Formule —</option>' +
      Object.entries(ROOMS).map(([k, r]) =>
        `<option value="${k}">${r.label}${r.capacity ? ` — max. ${r.capacity} pers.` : ''}</option>`
      ).join('');
  }
}

function _toggleLostReason(status) {
  const wrap = document.getElementById('lost-reason-wrap');
  if (wrap) wrap.style.display = status === 'lost' ? '' : 'none';
}

function _liveCapacityCheck() {
  const roomSel   = document.getElementById('deal-room-select');
  const guestsInp = document.getElementById('deal-nb-guests');
  const warnEl    = document.getElementById('capacity-warning');
  if (!roomSel || !guestsInp || !warnEl) return;

  const guests = parseInt(guestsInp.value);
  const warn   = isNaN(guests) || !roomSel.value ? null : validateRoomCapacity(roomSel.value, guests);
  warnEl.textContent    = warn || '';
  warnEl.style.display  = warn ? '' : 'none';
}

/* ────────────────────────────────────────────────────────────────
   SAVE DEAL
──────────────────────────────────────────────────────────────── */
async function saveDeal() {
  const data = getFormData('form-deal');

  if (!data.company_id && !data.title) {
    showToast('Veuillez renseigner un titre ou une entreprise', 'error'); return;
  }

  /* Alerte capacité (non bloquante) */
  if (data.room_type && data.nb_guests) {
    const warn = validateRoomCapacity(data.room_type, data.nb_guests);
    if (warn) showToast(warn, 'warning');
  }

  const btn = document.getElementById('btn-save-deal');
  if (btn) { btn.disabled = true; btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Enregistrement…'; }

  try {
    if (_editingDealId) {
      const updated = await updateDeal(_editingDealId, data);
      const idx = _allDeals.findIndex(d => d.id === _editingDealId);
      if (idx >= 0) _allDeals[idx] = { ..._allDeals[idx], ...updated };
      showToast('Deal mis à jour ✓', 'success');
      await logActivity({ deal_id: _editingDealId, type: 'edit', title: 'Deal modifié' });
    } else {
      const created = await createDeal(data);
      /* Recharger les companies jointes */
      const company = _allCompanies.find(c => String(c.id) === String(data.company_id));
      created.companies = company ? { id: company.id, name: company.name } : null;
      _allDeals.unshift(created);
      showToast('Deal créé ✓', 'success');
      await logActivity({ deal_id: created.id, type: 'create', title: 'Nouveau deal' });
    }
    closeModal('modal-deal');
    _rebuildPipeline();
    await updateGlobalKPIs();
  } catch (e) {
    showToast('Erreur : ' + e.message, 'error');
    console.error('[saveDeal]', e);
  } finally {
    if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fa-solid fa-check"></i> Enregistrer'; }
  }
}

/* ────────────────────────────────────────────────────────────────
   DELETE DEAL
──────────────────────────────────────────────────────────────── */
function confirmDeleteDealUI(id) {
  const deal = _allDeals.find(d => d.id === id);
  const name = deal?.title || deal?.companies?.name || `#${id}`;
  confirmAction(`Supprimer définitivement le deal « ${name} » ?`, async () => {
    try {
      await deleteDeal(id);
      _allDeals = _allDeals.filter(d => d.id !== id);
      closeModal('modal-deal');
      _rebuildPipeline();
      await updateGlobalKPIs();
      showToast('Deal supprimé', 'success');
    } catch (e) {
      showToast('Erreur suppression : ' + e.message, 'error');
    }
  });
}

