function checkQuoteRelances(quotes) {
  quotes
    .filter(q => q.status === 'sent' && q.sent_at && !q.signed_at)
    .forEach(q => {
      const daysSent = Math.abs(daysDiff(q.sent_at.split('T')[0]) || 0);
      if ([3, 7, 14].includes(daysSent)) {
        _addQuoteNotif(q, daysSent);
      }
    });
}

function _addQuoteNotif(q, days) {
