──────────────────────────────────────────────────────────────── */
function _renderFunnelChart(deals) {
  const el = document.getElementById('funnel-chart');
  if (!el) return;

  const stages = [
    { label: 'Nouveaux',   statuses: ['new'],      color: '#5b4cf0' },
    { label: 'En cours',   statuses: ['progress'], color: '#0284c7' },
    { label: 'À relancer', statuses: ['urgent'],   color: '#dc2626' },
    { label: 'Gagnés',     statuses: ['won'],       color: '#16a34a' },
    { label: 'Perdus',     statuses: ['lost'],      color: '#9a9690' },
  ];

  const rows = stages.map(s => ({
    ...s,
    count: deals.filter(d => s.statuses.includes(d.status)).length,
    value: deals.filter(d => s.statuses.includes(d.status)).reduce((sum, d) => sum + (Number(d.amount) || 0), 0),
  }));

  const maxCount = Math.max(...rows.map(r => r.count), 1);

  el.innerHTML = rows.map(row => {
    const pct = Math.max(20, Math.round((row.count / maxCount) * 100));
    return `
      <div class="funnel-row">
        <div class="funnel-label">${row.label}</div>
        <div class="funnel-bar-wrap">
          <div class="funnel-bar" style="width:${pct}%;background:${row.color}15;border-left:3px solid ${row.color}">
            <span class="funnel-count" style="color:${row.color}">${row.count}</span>
            <span class="funnel-value muted">${row.value > 0 ? _fmtE(row.value) : ''}</span>
          </div>
        </div>
      </div>`;
  }).join('');
}

