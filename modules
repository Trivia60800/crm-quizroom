   UTILS INTERNES
──────────────────────────────────────────────────────────────── */
function _detectCategory(filename, mime) {
  const n = filename.toLowerCase();
  if (n.includes('brochure') || n.includes('flyer') || n.includes('plaquette')) return 'brochures';
  if (n.includes('tarif') || n.includes('prix') || n.includes('cse') || n.includes('devis')) return 'tarifs';
  if (n.includes('cgv') || n.includes('contrat') || n.includes('accord')) return 'contrats';
  if (n.includes('ppt') || n.includes('presentation') || mime?.includes('presentation')) return 'presentations';
  return 'other';
}

function _formatFileSize(bytes) {
  if (!bytes) return '';
  if (bytes < 1024)         return bytes + ' o';
  if (bytes < 1_048_576)    return (bytes / 1024).toFixed(0)       + ' Ko';
  return (bytes / 1_048_576).toFixed(1) + ' Mo';
}

function _escHtml(s) {
  if (!s) return '';
  return String(s)
    .replace(/&/g,'&amp;').replace(/</g,'&lt;')
    .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

