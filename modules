/* ────────────────────────────────────────────────────────────────
   DESTINATAIRES (tags)
──────────────────────────────────────────────────────────────── */
function _addRecipient(email, name = '') {
  if (!email || _composeTo.find(r => r.email === email)) return;
  _composeTo.push({ email, name: name || email });
  _renderRecipients();
  const inp = document.getElementById('compose-to-input');
  if (inp) inp.value = '';
  _closeContactsDropdown();
}

function _removeRecipient(email) {
  _composeTo = _composeTo.filter(r => r.email !== email);
  _renderRecipients();
}

function _renderRecipients() {
  const container = document.getElementById('compose-recipients');
  if (!container) return;
  container.innerHTML = _composeTo.map(r => `
    <span class="compose-recipient-tag">
      ${r.name !== r.email ? `<strong>${_escHtml(r.name)}</strong> ` : ''}${_escHtml(r.email)}
      <button onclick="_removeRecipient('${r.email}')"><i class="fa-solid fa-xmark"></i></button>
    </span>`).join('');
}

function _handleToKeydown(e) {
  const val = e.target.value.trim();
  if ((e.key === 'Enter' || e.key === ',') && val) {
    e.preventDefault();
    if (val.includes('@')) _addRecipient(val);
  }
}

let _contactSearchTimer;
function _searchCRMContacts(query) {
  clearTimeout(_contactSearchTimer);
  if (!query || query.length < 2) { _closeContactsDropdown(); return; }
  _contactSearchTimer = setTimeout(async () => {
    const q   = query.toLowerCase();
    const { data } = await _sb
      .from('contacts')
      .select('id, first_name, last_name, email, companies(name)')
      .or(`email.ilike.%${q}%,last_name.ilike.%${q}%,first_name.ilike.%${q}%`)
      .limit(8);

    const dd = document.getElementById('compose-contacts-dropdown');
    if (!dd || !data?.length) { _closeContactsDropdown(); return; }

    dd.innerHTML = data.map(c => `
      <div class="contact-dd-item" onclick="_addRecipient('${c.email || ''}','${c.first_name || ''} ${c.last_name || ''}')">
        <div class="contact-dd-name">${_escHtml(c.first_name||'')} ${_escHtml(c.last_name||'')}</div>
        <div class="contact-dd-sub">${_escHtml(c.email||'—')} · ${_escHtml(c.companies?.name||'')}</div>
      </div>`).join('');
    dd.style.display = 'block';
  }, 200);
}

function _closeContactsDropdown() {
  const dd = document.getElementById('compose-contacts-dropdown');
  if (dd) dd.style.display = 'none';
}

document.addEventListener('click', e => {
  if (!e.target.closest('.compose-to-wrap')) _closeContactsDropdown();
});

/* ────────────────────────────────────────────────────────────────
   PIÈCES JOINTES
──────────────────────────────────────────────────────────────── */
function _openMediaSelectorForEmail() {
  openMediaSelectorModal(async (fileIds) => {
    for (const id of fileIds) {
      const att = await fetchFileAsBase64(id);
      if (att && !_currentAttachments.find(a => a.fileId === id)) {
        _currentAttachments.push({ ...att, fileId: id });
      }
    }
    _renderAttachments();
  });
}

async function _addLocalAttachments(e) {
  const files = Array.from(e.target.files || []);
  for (const file of files) {
    await new Promise((resolve) => {
      const reader = new FileReader();
      reader.onload = ev => {
        const b64 = ev.target.result.split(',')[1];
        _currentAttachments.push({ name: file.name, mimeType: file.type, data: b64 });
        resolve();
      };
      reader.readAsDataURL(file);
    });
  }
  _renderAttachments();
  e.target.value = '';
}

function _removeAttachment(index) {
  _currentAttachments.splice(index, 1);
  _renderAttachments();
}

function _renderAttachments() {
  const list = document.getElementById('compose-attachments-list');
  if (!list) return;
  if (!_currentAttachments.length) { list.innerHTML = ''; return; }
  list.innerHTML = _currentAttachments.map((a, i) => `
    <div class="compose-att-item">
      <i class="fa-solid fa-paperclip"></i>
      <span>${_escHtml(a.name)}</span>
      <button class="btn-icon" style="width:22px;height:22px;font-size:.7rem" onclick="_removeAttachment(${i})">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>`).join('');
}

/* Pré-chargement des PJ depuis médiathèque (ouverture contextuelle) */
async function _prefillAttachments(fileIds = []) {
  for (const id of fileIds) {
    const att = await fetchFileAsBase64(id);
    if (att) _currentAttachments.push({ ...att, fileId: id });
  }
  _renderAttachments();
}

