function openAddCompanyModal(prefill = {}) {
  _injectCompanyModal();
  document.getElementById('company-modal-title').textContent = 'Nouvelle entreprise';
  document.getElementById('cm-id').value = '';
  document.getElementById('cm-delete-btn').style.display = 'none';
  ['name','sector','source','address','city','phone','email','website','notes'].forEach(f => {
    const el = document.getElementById('cm-' + f);
    if (el) el.value = prefill[f] || (f==='source' ? 'manual' : '');
  });
  openModal('company-modal');
}

async function openEditCompanyModal(id) {
  _injectCompanyModal();
  const { data } = await _sb.from('companies').select('*').eq('id', id).single();
  if (!data) return;
  document.getElementById('company-modal-title').textContent = 'Modifier l\'entreprise';
  document.getElementById('cm-id').value = id;
  document.getElementById('cm-delete-btn').style.display = '';
  ['name','sector','source','address','city','phone','email','website','notes'].forEach(f => {
    const el = document.getElementById('cm-' + f);
    if (el) el.value = data[f] || '';
  });
  openModal('company-modal');
}

async function _saveCompany() {
  const name = document.getElementById('cm-name')?.value?.trim();
  if (!name) { showToast('Le nom est obligatoire', 'error'); return; }

  const payload = {
    name,
    sector:  document.getElementById('cm-sector')?.value  || null,
    source:  document.getElementById('cm-source')?.value  || 'manual',
    address: document.getElementById('cm-address')?.value || null,
    city:    document.getElementById('cm-city')?.value    || null,
    phone:   document.getElementById('cm-phone')?.value   || null,
    email:   document.getElementById('cm-email')?.value   || null,
    website: document.getElementById('cm-website')?.value || null,
    notes:   document.getElementById('cm-notes')?.value   || null,
  };

  const id = document.getElementById('cm-id')?.value;
  try {
    if (id) {
      await updateCompany(parseInt(id), payload);
      showToast('Entreprise mise à jour ✓', 'success');
    } else {
      await createCompany(payload);
      showToast('Entreprise créée ✓', 'success');
    }
    closeModal('company-modal');
    if (_currentDetailId) openCompanyDetail(_currentDetailId);
    else { _companiesAll = await fetchCompanies(); _buildCompaniesView(); }
  } catch (e) {
    showToast('Erreur : ' + e.message, 'error');
  }
}

function _confirmDeleteCompanyFromModal() {
  const id = parseInt(document.getElementById('cm-id')?.value);
  if (!id) return;
  confirmAction('Supprimer cette entreprise et toutes ses données ?', async () => {
    try { await deleteCompany(id); showToast('Entreprise supprimée', 'success'); closeModal('company-modal'); navigate('companies'); }
    catch (e) { showToast('Erreur : ' + e.message, 'error'); }
  });
}

function _confirmDeleteCompany(id) {
  confirmAction('Supprimer cette entreprise ?', async () => {
    try { await deleteCompany(id); showToast('Entreprise supprimée', 'success'); _companiesAll = await fetchCompanies(); _buildCompaniesView(); }
    catch (e) { showToast('Erreur : ' + e.message, 'error'); }
  });
}

