}

/* ────────────────────────────────────────────────────────────────
   EXPORT PDF (basique — capture viewport)
──────────────────────────────────────────────────────────────── */
async function exportAnalyticsPDF() {
  if (typeof html2canvas === 'undefined' || typeof jspdf === 'undefined') {
    showToast('Bibliothèques PDF non chargées', 'error');
    return;
  }
  showLoader('Génération du PDF…');
  try {
    const el      = document.querySelector('.analytics-container');
    const canvas  = await html2canvas(el, { scale: 1.5, useCORS: true, backgroundColor: '#f7f6f3' });
    const { jsPDF } = jspdf;
    const pdf     = new jsPDF({ orientation: 'p', unit: 'mm', format: 'a4' });
    const pdfW    = pdf.internal.pageSize.getWidth();
    const ratio   = canvas.width / canvas.height;
    const pdfH    = pdfW / ratio;
    pdf.addImage(canvas.toDataURL('image/jpeg', 0.85), 'JPEG', 0, 0, pdfW, pdfH);
    pdf.save(`analytique_${new Date().toISOString().split('T')[0]}.pdf`);
    showToast('PDF généré ✓', 'success');
  } catch (e) {
    showToast('Erreur PDF : ' + e.message, 'error');
  } finally {
    hideLoader();
  }
}

/* ────────────────────────────────────────────────────────────────
   HELPERS
──────────────────────────────────────────────────────────────── */
function _getMonthRange(fromStr) {
  const MOIS = ['Jan','Fév','Mar','Avr','Mai','Jun','Jul','Aoû','Sep','Oct','Nov','Déc'];
  const from = new Date(fromStr);
  const now  = new Date();
  const months = [];
  const cur  = new Date(from.getFullYear(), from.getMonth(), 1);
  while (cur <= now) {
    months.push({
      key:   `${cur.getFullYear()}-${String(cur.getMonth()+1).padStart(2,'0')}`,
      label: `${MOIS[cur.getMonth()]} ${String(cur.getFullYear()).slice(2)}`,
    });
    cur.setMonth(cur.getMonth() + 1);
  }
  return months;
}

function _daysSince(dateStr) {
  if (!dateStr) return 999;
  return Math.round((new Date() - new Date(dateStr)) / 86_400_000);
}

function _daysBetween(d1, d2) {
  try { return Math.abs(Math.round((new Date(d2) - new Date(d1)) / 86_400_000)); }
  catch { return 0; }
}

function _firstDayOfMonth() {
  const n = new Date();
  return new Date(n.getFullYear(), n.getMonth(), 1).toISOString().split('T')[0];
}

function _fmtE(v) {
  if (!v) return '0 €';
  return Number(v).toLocaleString('fr-FR', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 });
}

function _esc(s) {
  if (!s) return '';
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function _setEl(id, html) {
  const el = document.getElementById(id);
  if (el) el.innerHTML = html;
}

