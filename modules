/* ── Onglets ─────────────────────────────────────────────── */
function switchScriptTab(tab, btnEl) {
  currentScriptType = tab;
  ['email','tel','saved'].forEach(t => {
    const el = document.getElementById(`tab-${t}`);
    if (el) el.style.display = t === tab ? '' : 'none';
  });
  document.querySelectorAll('#script-tabs .script-tab').forEach(b => {
    b.classList.toggle('active', b.dataset.tab === tab);
  });
  if (tab === 'saved') _loadSavedTemplates();
}

/* ── Génération ─────────────────────────────────────────── */
async function generateScript(type) {
  if (!currentScriptCompany) return;

  if (type === 'email') {
    const subEl  = document.getElementById('script-email-subject');
    const bodyEl = document.getElementById('script-email-body');
    if (subEl)  { subEl.value  = ''; subEl.placeholder  = '⏳ Génération…'; }
    if (bodyEl) { bodyEl.value = ''; bodyEl.placeholder = '⏳ Génération…'; }
    try {
      const result = await generateEmailScript(currentScriptCompany);
      if (subEl)  subEl.value  = result.subject || '';
      if (bodyEl) bodyEl.value = result.body    || '';
    } catch (e) {
      showToast('Erreur génération email : ' + e.message, 'error');
      if (subEl)  subEl.placeholder  = 'Erreur — vérifiez la clé Claude API';
      if (bodyEl) bodyEl.placeholder = e.message;
    }

  } else if (type === 'tel') {
    const zone = document.getElementById('script-phone-content');
    if (zone) zone.innerHTML = `<div class="page-loading" style="min-height:120px"><div class="spinner"></div><p>Génération…</p></div>`;
    try {
      savedPhoneScript = await generatePhoneScript(currentScriptCompany);
      if (savedPhoneScript && zone) {
        zone.innerHTML = _renderPhoneScript(savedPhoneScript);
      } else if (zone) {
        zone.innerHTML = '<p style="color:var(--urgent);padding:16px">Erreur de génération.</p>';
      }
    } catch (e) {
      showToast('Erreur génération tél : ' + e.message, 'error');
      if (zone) zone.innerHTML = `<p style="color:var(--urgent);padding:16px">${e.message}</p>`;
    }
  }
}

function _renderPhoneScript(script) {
  if (!script) return '<p style="padding:16px;color:var(--muted)">Script non disponible.</p>';

  const sections = [
    { icon: '🎯', title: 'Accroche (10 sec)',          content: script.accroche          || '' },
    { icon: '🎮', title: 'Présentation Quiz Room',      content: script.presentation      || '' },
    { icon: '💬', title: 'Question pivot',              content: script.question_pivot    || '' },
    { icon: '🛡️', title: 'Gestion des objections',     content: _renderObjections(script.objections) },
    { icon: '📅', title: 'Conclusion & CTA',            content: script.cta               || '' },
  ];

  return sections.map((s, i) => `
    <div class="phone-section">
      <div class="phone-section-header" onclick="_togglePhoneSection(this)">
        <span>${s.icon} ${s.title}</span>
        <i class="fa-solid fa-chevron-down"></i>
      </div>
      <div class="phone-section-body${i > 0 ? ' collapsed' : ''}">${s.content}</div>
    </div>`).join('');
}

function _renderObjections(objections) {
  if (!Array.isArray(objections) || objections.length === 0) return '—';
  return objections.map(o => `
    <div class="objection-row">
      <div class="objection-q">❓ <em>${o.objection}</em></div>
      <div class="objection-a">💡 ${o.reponse}</div>
    </div>`).join('');
}

function _togglePhoneSection(headerEl) {
  const body = headerEl.nextElementSibling;
  if (!body) return;
  const isOpen = !body.classList.contains('collapsed');
  body.classList.toggle('collapsed', isOpen);
  const icon = headerEl.querySelector('i');
  if (icon) icon.style.transform = isOpen ? '' : 'rotate(180deg)';
}

/* ── Copier ─────────────────────────────────────────────── */
function copyScript(type) {
  let text = '';
  if (type === 'email') {
    const subj = document.getElementById('script-email-subject')?.value || '';
    const body = document.getElementById('script-email-body')?.value    || '';
    text = subj ? `Objet : ${subj}\n\n${body}` : body;
  } else if (type === 'tel' && savedPhoneScript) {
    const s = savedPhoneScript;
    text = [
      `🎯 Accroche\n${s.accroche}`,
      `🎮 Présentation\n${s.presentation}`,
      `💬 Question pivot\n${s.question_pivot}`,
      `🛡️ Objections\n${(s.objections||[]).map(o=>`• ${o.objection} → ${o.reponse}`).join('\n')}`,
      `📅 CTA\n${s.cta}`,
    ].join('\n\n');
  }
  if (!text) { showToast('Rien à copier', 'warning'); return; }
  navigator.clipboard.writeText(text)
    .then(() => showToast('Copié dans le presse-papier ✓', 'success'))
    .catch(() => showToast('Copie impossible (HTTP requis)', 'error'));
}

/* ── Templates ──────────────────────────────────────────── */
async function saveAsTemplate(type) {
  const name = prompt('Nom de ce template :');
  if (!name?.trim()) return;

  const body = type === 'email'
    ? document.getElementById('script-email-body')?.value  || ''
    : JSON.stringify(savedPhoneScript || {});
  const subject = type === 'email'
    ? document.getElementById('script-email-subject')?.value || ''
    : null;

  try {
    const { error } = await _sb.from('templates').insert([{
      name: name.trim(), type, subject, body,
      tags: [currentScriptCompany?.sector || 'général'],
    }]);
    if (error) throw new Error(error.message);
    showToast('Template sauvegardé !', 'success');
  } catch (e) {
    // Table templates peut ne pas exister encore
    showToast('Erreur sauvegarde template : ' + e.message, 'error');
  }
}

async function _loadSavedTemplates() {
  const container = document.getElementById('saved-templates-list');
  if (!container) return;
  container.innerHTML = '<div class="page-loading" style="min-height:100px"><div class="spinner"></div></div>';

  const { data, error } = await _sb.from('templates').select('*').order('created_at', { ascending: false });
  if (error || !data?.length) {
    container.innerHTML = `<div class="prosp-empty-state" style="min-height:120px">
      <i class="fa-solid fa-bookmark"></i><p>Aucun template sauvegardé</p></div>`;
    return;
  }

  container.innerHTML = data.map(t => `
    <div class="template-card">
      <div class="template-card-top">
        <span class="template-type-badge">${t.type === 'email' ? '📧 Email' : '📞 Tél'}</span>
        <strong>${t.name}</strong>
