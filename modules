──────────────────────────────────────────────────────────────── */
async function _loadEmailHistory() {
  const { data } = await _sb
    .from('activities')
    .select('*, companies(name)')
    .eq('type', 'email')
    .order('created_at', { ascending: false })
    .limit(100);

  _emailHistoryData = data || [];
  _filterEmailHistory();
}

function _filterEmailHistory() {
  const list = document.getElementById('email-history-list');
  if (!list) return;

  const q      = _emailSearchQuery;
  const items  = q
    ? _emailHistoryData.filter(a =>
        (a.title || '').toLowerCase().includes(q) ||
        (a.companies?.name || '').toLowerCase().includes(q))
    : _emailHistoryData;

  const badge = document.getElementById('email-count');
  if (badge) badge.textContent = _emailHistoryData.length;

  if (!items.length) {
    list.innerHTML = '<div class="empty-state-sm"><i class="fa-solid fa-inbox"></i> Aucun email envoyé</div>';
    return;
  }

  list.innerHTML = items.map(a => {
    const meta = a.metadata || {};
    const atts = meta.attachments?.length || 0;
    return `
      <div class="email-history-item" onclick="_previewEmail(${a.id})">
        <div class="email-hist-company">${_escHtml(a.companies?.name || (meta.to?.[0] || '—'))}</div>
        <div class="email-hist-subject">${_escHtml(a.title || '(sans objet)')}</div>
        <div class="email-hist-meta">
          <span class="muted">${timeAgo(a.created_at)}</span>
          ${atts ? `<span class="muted"><i class="fa-solid fa-paperclip"></i> ${atts}</span>` : ''}
        </div>
      </div>`;
  }).join('');
}

async function _previewEmail(activityId) {
  const act = _emailHistoryData.find(a => a.id === activityId);
  if (!act) return;

  const meta = act.metadata || {};
  const modal = document.createElement('div');
  modal.className = 'modal open';
  modal.innerHTML = `
    <div class="modal-box" style="max-width:560px">
      <div class="modal-header">
        <h2>Email envoyé</h2>
        <button class="modal-close" onclick="this.closest('.modal').remove()">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>
      <div class="modal-body">
        <div class="email-preview-row"><span>À :</span><strong>${_escHtml((meta.to||[]).join(', '))}</strong></div>
        ${meta.cc ? `<div class="email-preview-row"><span>CC :</span><strong>${_escHtml(meta.cc)}</strong></div>` : ''}
        <div class="email-preview-row"><span>Objet :</span><strong>${_escHtml(act.title)}</strong></div>
        <div class="email-preview-row"><span>Date :</span><span>${formatDate(act.created_at)}</span></div>
        ${(meta.attachments||[]).length ? `
          <div class="email-preview-row">
            <span>PJ :</span>
            <span>${meta.attachments.map(n => `<span class="prosp-chip">${_escHtml(n)}</span>`).join(' ')}</span>
          </div>` : ''}
        <div class="email-preview-body">${act.body || '<em>Corps non sauvegardé</em>'}</div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary" onclick="this.closest('.modal').remove()">Fermer</button>
        <button class="btn btn-primary" onclick="this.closest('.modal').remove();_replyToEmail(${activityId})">
          <i class="fa-solid fa-reply"></i> Répondre
        </button>
      </div>
    </div>`;
  document.body.appendChild(modal);
  modal.addEventListener('click', e => { if (e.target === modal) modal.remove(); });
}

function _replyToEmail(activityId) {
  const act  = _emailHistoryData.find(a => a.id === activityId);
  if (!act) return;
  const meta = act.metadata || {};
  const to   = meta.to?.[0] || '';
  if (to) _addRecipient(to, act.companies?.name || to);
  const subEl = document.getElementById('compose-subject');
  if (subEl) subEl.value = `Re : ${act.title || ''}`;
  document.getElementById('compose-body')?.focus();
}

/* ────────────────────────────────────────────────────────────────
   OUVERTURE CONTEXTUELLE (depuis pipeline, fiche, etc.)
──────────────────────────────────────────────────────────────── */
function openComposeEmail(context = {}) {
  if (currentSection !== 'email') {
    _composeContext = context;
    navigate('email');
    return;
  }
  _applyComposeContext(context);
}

function _applyComposeContext(ctx) {
  if (!ctx) return;
  _composeContext = ctx;

  if (ctx.to) _addRecipient(ctx.to, ctx.company_name || ctx.to);
  if (ctx.subject) {
    const subEl = document.getElementById('compose-subject');
    if (subEl) subEl.value = ctx.subject;
  }
  if (ctx.body) {
    const bodyEl = document.getElementById('compose-body');
    if (bodyEl) bodyEl.innerHTML = ctx.body.replace(/\n/g, '<br>');
  }
  if (ctx.prefillAttachments?.length) {
    _prefillAttachments(ctx.prefillAttachments);
  }

  _loadSignature();
}

