function _openSidePanel(html) {
  let panel = document.getElementById('place-detail-panel');
  if (!panel) {
    panel = document.createElement('div');
    panel.id = 'place-detail-panel';
    panel.className = 'side-panel';
    document.body.appendChild(panel);
  }
  panel.innerHTML = html;
  requestAnimationFrame(() => panel.classList.add('open'));
}

function _sideBodyHTML(html) {
  let panel = document.getElementById('place-detail-panel');
  if (!panel) return;
  let body = panel.querySelector('.side-panel-body');
  if (!body) { body = document.createElement('div'); body.className = 'side-panel-body'; panel.appendChild(body); }
  body.innerHTML = html;
}

function closePlacePanel() {
  const panel = document.getElementById('place-detail-panel');
  if (panel) {
    panel.classList.remove('open');
    setTimeout(() => panel.remove(), 280);
  }
  currentPlaceData  = null;
  currentAIAnalysis = null;
}

/* ────────────────────────────────────────────────────────────────
   AJOUT AU CRM
──────────────────────────────────────────────────────────────── */
async function addToCRMFromSearch(placeId) {
  // Vérifier doublon rapide
  if (prospExistingIds.has(placeId)) {
    showToast('Cette entreprise est déjà dans le CRM', 'info'); return;
  }
  // Charger les détails si pas encore en cache
  if (!currentPlaceData || currentPlaceData.place_id !== placeId) {
    showLoader('Récupération des données…');
    const place = await _fetchPlaceDetails(placeId);
    if (!place) { hideLoader(); showToast('Impossible de récupérer les détails', 'error'); return; }
    currentPlaceData = place;
    currentPlaceData.place_id = placeId;
    currentAIAnalysis = null;
    hideLoader();
  }
  await _doAddToCRM(placeId);
}

async function addToCRMFromPanel() {
  if (!currentPlaceData) return;
  await _doAddToCRM(currentPlaceData.place_id);
}

async function _doAddToCRM(placeId) {
  if (prospExistingIds.has(placeId)) {
    showToast('Déjà dans le CRM', 'info'); return;
  }
  const place = currentPlaceData;
  if (!place) return;

  try {
    const company = await createCompany({
      name:            place.name,
      address:         place.formatted_address || null,
      city:            _extractCity(place.formatted_address),
      phone:           place.formatted_phone_number || null,
      website:         place.website || null,
      google_place_id: placeId,
      source:          'prospection',
      ai_score:        currentAIAnalysis?.score_pertinence || 0,
      notes:           currentAIAnalysis
        ? `[IA] ${currentAIAnalysis.potentiel || ''}`
        : null,
      sector:          currentAIAnalysis?.type_cible || null,
    });

    prospExistingIds.add(placeId);
    showToast(`✅ ${place.name} ajouté au CRM !`, 'success');
    await logActivity({ company_id: company.id, type: 'create', title: 'Entreprise ajoutée depuis la prospection' });

    // Refresh markers & cards
    _renderResults(prospResults, false);
    _placeMarkers(prospResults);

    // Mise à jour du panel ouvert
    const actionZone = document.querySelector('.place-actions');
    if (actionZone) {
      const addBtn = actionZone.querySelector('.btn-primary');
      if (addBtn) addBtn.outerHTML = `<span class="already-in-crm large"><i class="fa-solid fa-check"></i> Dans le CRM</span>`;
    }

    // Proposition créer un deal
    if (confirm(`Voulez-vous créer un deal pour ${place.name} ?`)) {
      closePlacePanel();
      navigate('pipeline');
      setTimeout(() => openAddModal(), 300);
    }
  } catch (e) {
    showToast('Erreur ajout CRM : ' + e.message, 'error');
  }
}

