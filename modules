/* ────────────────────────────────────────────────────────────────
   BAR CHART CA 12 MOIS
──────────────────────────────────────────────────────────────── */
function _renderCAChart(deals) {
  const canvas = document.getElementById('chart-ca');
  if (!canvas || typeof Chart === 'undefined') return;

  const months   = _getLast12Months();
  const wonDeals = deals.filter(d => d.status === 'won');

  const data = months.map(m => wonDeals
    .filter(d => {
      const dStr = (d.updated_at || d.created_at || '').slice(0, 7);
      return dStr === m.key;
    })
    .reduce((s, d) => s + (Number(d.amount) || 0), 0)
  );

  const maxVal   = Math.max(...data, 1);
  const gradient = canvas.getContext('2d');
  const bg       = gradient.createLinearGradient(0, 0, 0, 200);
  bg.addColorStop(0,   'rgba(91,76,240,0.8)');
  bg.addColorStop(1,   'rgba(91,76,240,0.2)');

  _chartCA = new Chart(canvas, {
    type: 'bar',
    data: {
      labels:   months.map(m => m.label),
      datasets: [{
        label: 'CA (€)',
        data,
        backgroundColor: data.map((v, i) =>
          i === months.length - 1 ? 'rgba(91,76,240,0.95)' : 'rgba(91,76,240,0.55)'
        ),
        borderRadius: 8,
        borderSkipped: false,
        borderWidth: 0,
      }],
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: ctx => '  ' + _fmtE(ctx.raw),
          },
        },
      },
      scales: {
        y: {
          beginAtZero: true,
          ticks: {
            callback: v => v === 0 ? '0' : (v / 1000).toFixed(0) + 'k €',
            font: { size: 11 },
            color: '#9a9690',
          },
          grid: { color: '#e8e6e1' },
        },
        x: {
