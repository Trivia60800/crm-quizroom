──────────────────────────────────────────────────────────────── */
async function duplicateQuote(id) {
  const { data, error } = await _sb.from('quotes').select('*').eq('id', id).single();
  if (error || !data) { showToast('Devis introuvable', 'error'); return; }

  const newNumber = await generateQuoteNumber();
  const valid     = new Date(); valid.setDate(valid.getDate() + 30);

  const { error: err2 } = await _sb.from('quotes').insert([{
    ...data,
    id:           undefined,
    quote_number: newNumber,
    status:       'draft',
    sent_at:      null,
    signed_at:    null,
    pdf_url:      null,
    created_at:   new Date().toISOString(),
    updated_at:   new Date().toISOString(),
    valid_until:  valid.toISOString().split('T')[0],
  }]);

  if (err2) { showToast('Erreur duplication : ' + err2.message, 'error'); return; }
  showToast(`Devis dupliqué → ${newNumber}`, 'success');
  await _loadQuoteData();
  _rebuildQuotesView();
}

/* ────────────────────────────────────────────────────────────────
   GÉNÉRATION PDF
──────────────────────────────────────────────────────────────── */
async function downloadQuotePDF(quoteId) {
  const id = quoteId || _currentQuoteId;
  if (!id) {
    /* Pré-enregistrement si nouveau devis avec des lignes */
    if (_currentQuoteLines.length === 0) {
      showToast('Ajoutez au moins une prestation avant de générer le PDF', 'warning');
      return;
    }
    showToast('Enregistrez d\'abord le devis pour générer le PDF', 'info');
    return;
  }

  showLoader('Génération du PDF…');

  try {
    const { data: quote } = await _sb.from('quotes').select('*').eq('id', id).single();
    if (!quote) { hideLoader(); showToast('Devis introuvable', 'error'); return; }

    const company = quote.company_id
      ? _allCompaniesQ.find(c => c.id === quote.company_id) || null
      : null;
    const contact = quote.contact_id
      ? _allContactsQ.find(c => c.id === quote.contact_id) || null
      : null;

    const lines = Array.isArray(quote.lines)
      ? quote.lines
      : (quote.lines ? JSON.parse(quote.lines) : []);

    const html = _buildQuotePDFHtml({ ...quote, lines }, company, contact);

    await _renderPDF(html, `Devis_${quote.quote_number}_QuizRoom.pdf`);
    hideLoader();
    showToast('PDF téléchargé ✓', 'success');

  } catch (e) {
    hideLoader();
    showToast('Erreur PDF : ' + e.message, 'error');
    console.error('[downloadQuotePDF]', e);
  }
}

async function _renderPDF(htmlContent, filename) {
  /* Vérifier les libs */
  if (!window.jspdf || !window.html2canvas) {
    throw new Error('jsPDF ou html2canvas non chargé. Vérifiez les CDN dans index.html.');
  }

  const iframe = document.createElement('iframe');
  iframe.style.cssText = 'position:fixed;width:210mm;height:297mm;left:-9999px;top:0;border:none;visibility:hidden';
  document.body.appendChild(iframe);

  iframe.contentDocument.open();
  iframe.contentDocument.write(htmlContent);
  iframe.contentDocument.close();

  /* Attendre le rendu des images/fonts */
  await new Promise(r => setTimeout(r, 1000));

  try {
    const canvas = await html2canvas(iframe.contentDocument.body, {
      scale:        2,
      useCORS:      true,
      backgroundColor: '#ffffff',
      width:        794,  // ~210mm @ 96dpi
      windowWidth:  794,
    });

    const imgData = canvas.toDataURL('image/jpeg', 0.95);
    const { jsPDF } = window.jspdf;
    const pdf = new jsPDF('p', 'mm', 'a4');
    const ratio = canvas.height / canvas.width;
    const pageW = 210;
    const pageH = pageW * ratio;

    /* Gérer multi-pages si contenu dépasse A4 */
    if (pageH > 297) {
      const pages = Math.ceil(pageH / 297);
      for (let i = 0; i < pages; i++) {
        if (i > 0) pdf.addPage();
        pdf.addImage(imgData, 'JPEG', 0, -i * 297, pageW, pageH);
      }
    } else {
      pdf.addImage(imgData, 'JPEG', 0, 0, pageW, pageH);
    }

    pdf.save(filename);
  } finally {
    document.body.removeChild(iframe);
  }
}

