──────────────────────────────────────────────────────────────── */
function addQuoteLine(prefill = {}) {
  const line = {
    id:          crypto.randomUUID(),
    description: prefill.description || '',
    qty:         prefill.qty         || 1,
    unit_price:  prefill.unit_price  || 0,
    discount:    prefill.discount    || 0,
    total_ht:    prefill.total_ht    || 0,
  };
  _currentQuoteLines.push(line);
  _renderAllQuoteLines();
  recalcQuote();
}

function _renderAllQuoteLines() {
  const container = document.getElementById('quote-lines-container');
  if (!container) return;
  if (_currentQuoteLines.length === 0) {
    container.innerHTML = '<p class="muted" style="font-size:.82rem;padding:8px 0">Aucune prestation — ajoutez une ligne ou choisissez dans le catalogue.</p>';
    return;
  }
  container.innerHTML = _currentQuoteLines.map(_renderQuoteLine).join('');
}

function _renderQuoteLine(line) {
  return `
    <div class="quote-line" data-line-id="${line.id}">
      <div class="ql-description">
        <input type="text" class="ql-input" value="${escHtml(line.description)}"
          placeholder="Description de la prestation…"
          oninput="updateLine('${line.id}','description',this.value)">
      </div>
      <div class="ql-qty">
        <input type="number" class="ql-input" value="${line.qty}" min="1"
          oninput="updateLine('${line.id}','qty',+this.value)">
      </div>
      <div class="ql-price">
        <input type="number" class="ql-input" value="${line.unit_price}" step="10" min="0"
          oninput="updateLine('${line.id}','unit_price',+this.value)">
        <span class="ql-unit">€</span>
      </div>
      <div class="ql-discount">
        <input type="number" class="ql-input" value="${line.discount}" min="0" max="100"
          oninput="updateLine('${line.id}','discount',+this.value)">
        <span class="ql-unit">%</span>
      </div>
      <div class="ql-total">
        <strong id="ql-total-${line.id}">${fmtEuro(line.total_ht)}</strong>
      </div>
      <button class="btn-icon" style="color:var(--urgent)" onclick="removeLine('${line.id}')" title="Supprimer">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>`;
}

function updateLine(id, field, value) {
  const line = _currentQuoteLines.find(l => l.id === id);
  if (!line) return;
  line[field] = value;
  recalcQuote();
}

function removeLine(id) {
  _currentQuoteLines = _currentQuoteLines.filter(l => l.id !== id);
  _renderAllQuoteLines();
  recalcQuote();
}

/* ────────────────────────────────────────────────────────────────
   RECALCUL TEMPS RÉEL
──────────────────────────────────────────────────────────────── */
function recalcQuote() {
  let subtotal = 0;
  _currentQuoteLines.forEach(line => {
    const qty   = parseFloat(line.qty)        || 0;
    const price = parseFloat(line.unit_price)  || 0;
    const disc  = parseFloat(line.discount)    || 0;
    line.total_ht = qty * price * (1 - disc / 100);
    subtotal += line.total_ht;
    const el = document.getElementById(`ql-total-${line.id}`);
    if (el) el.textContent = fmtEuro(line.total_ht);
  });

  const discPct  = parseFloat(document.getElementById('qf-discount')?.value) || 0;
  const discAmt  = subtotal * discPct / 100;
  const afterD   = subtotal - discAmt;
  const tva      = afterD * 0.20;
  const totalTTC = afterD + tva;

  const _set = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val; };
  _set('sum-subtotal', fmtEuro(subtotal));
  _set('sum-discount', '−' + fmtEuro(discAmt));
  _set('sum-tva',      fmtEuro(tva));
  _set('sum-total',    fmtEuro(totalTTC));

  const discRow = document.getElementById('discount-amount-row');
  if (discRow) discRow.style.display = discPct > 0 ? 'flex' : 'none';

  _renderSummaryLines();
  return { subtotal, discAmt, tva, totalTTC };
}

function _renderSummaryLines() {
  const container = document.getElementById('summary-lines');
  if (!container) return;
  if (!_currentQuoteLines.length) { container.innerHTML = ''; return; }
  container.innerHTML = _currentQuoteLines.map(l => `
    <div class="summary-line-row">
      <span class="summary-line-desc">${escHtml(l.description || '—')}</span>
      <span class="summary-line-total">${fmtEuro(l.total_ht)}</span>
    </div>`).join('');
}

