/* ────────────────────────────────────────────────────────────────
   NUMÉROTATION
──────────────────────────────────────────────────────────────── */
async function generateQuoteNumber() {
  const year = new Date().getFullYear();
  const { count } = await _sb
    .from('quotes')
    .select('id', { count: 'exact', head: true })
    .gte('created_at', `${year}-01-01T00:00:00`);
  const seq = String((count || 0) + 1).padStart(3, '0');
  return `QR-${year}-${seq}`;
}

/* ────────────────────────────────────────────────────────────────
   SAVE / UPDATE
──────────────────────────────────────────────────────────────── */
async function saveQuote() {
  const { subtotal, discAmt, tva, totalTTC } = recalcQuote();

  const companyId = document.getElementById('qf-company')?.value         || null;
  const contactId = document.getElementById('qf-contact')?.value         || null;
  const status    = document.getElementById('qf-status')?.value          || 'draft';
  const notes     = document.getElementById('qf-notes')?.value           || '';
  const validUntil= document.getElementById('qf-valid-until')?.value     || null;
  const discPct   = parseFloat(document.getElementById('qf-discount')?.value) || 0;
  const compFree  = document.getElementById('qf-company-free')?.value?.trim() || null;

  if (!companyId && !compFree && _currentQuoteLines.length === 0) {
    showToast('Renseignez au moins un client ou une prestation', 'error');
    return;
  }

  const payload = {
    company_id:      companyId ? parseInt(companyId) : null,
    contact_id:      contactId ? parseInt(contactId) : null,
    status,
    lines:           _currentQuoteLines,
    subtotal_ht:     subtotal,
    discount_global: discPct,
    tva_rate:        20,
    total_ttc:       totalTTC,
    notes:           notes || null,
    valid_until:     validUntil || null,
    updated_at:      new Date().toISOString(),
  };

  /* Timestamps automatiques */
  if (status === 'sent' && !_currentQuote?.sent_at) {
    payload.sent_at = new Date().toISOString();
  }
  if (status === 'signed' && !_currentQuote?.signed_at) {
    payload.signed_at = new Date().toISOString();
  }

  const btn = document.getElementById('quote-modal')?.querySelector('.btn-primary[onclick="saveQuote()"]');
  if (btn) { btn.disabled = true; btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>'; }

  try {
    if (_currentQuoteId) {
      const { error } = await _sb.from('quotes').update(payload).eq('id', _currentQuoteId);
      if (error) throw new Error(error.message);

      /* Log activité signature */
      if (status === 'signed' && !_currentQuote?.signed_at) {
        await logActivity({
          company_id: companyId ? parseInt(companyId) : null,
          deal_id: _currentQuote?.deal_id || null,
          type:    'quote_signed',
          title:   `Devis ${_currentQuote?.quote_number} signé`,
        });
      }
      showToast('Devis mis à jour ✓', 'success');
    } else {
      payload.quote_number = await generateQuoteNumber();
      payload.created_at   = new Date().toISOString();
      const { data, error } = await _sb.from('quotes').insert([payload]).select().single();
      if (error) throw new Error(error.message);
      await logActivity({
        company_id: companyId ? parseInt(companyId) : null,
        type: 'quote_created',
        title: `Devis ${payload.quote_number} créé`,
      });
      showToast(`Devis ${payload.quote_number} créé ✓`, 'success');
    }
    closeQuoteModal();
    await _loadQuoteData();
    _rebuildQuotesView();
    await updateGlobalKPIs();
  } catch (e) {
    showToast('Erreur : ' + e.message, 'error');
    console.error('[saveQuote]', e);
  } finally {
    if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fa-solid fa-check"></i> Enregistrer'; }
  }
}

