/* ────────────────────────────────────────────────────────────────
   CALCUL KPIs
──────────────────────────────────────────────────────────────── */
function _computeKPIs(deals, quotes) {
  const now   = new Date();
  const t     = today();

  const curMonthStart  = new Date(now.getFullYear(), now.getMonth(), 1).toISOString().split('T')[0];
  const prevMonthStart = new Date(now.getFullYear(), now.getMonth() - 1, 1).toISOString().split('T')[0];
  const prevMonthEnd   = new Date(now.getFullYear(), now.getMonth(), 0).toISOString().split('T')[0];

  const wonCur  = deals.filter(d => d.status === 'won' && (d.updated_at||'').slice(0,10) >= curMonthStart)
                       .reduce((s, d) => s + (Number(d.amount) || 0), 0);
  const wonPrev = deals.filter(d => d.status === 'won'
                       && (d.updated_at||'').slice(0,10) >= prevMonthStart
                       && (d.updated_at||'').slice(0,10) <= prevMonthEnd)
                       .reduce((s, d) => s + (Number(d.amount) || 0), 0);

  const trendPct = wonPrev > 0 ? Math.round((wonCur - wonPrev) / wonPrev * 100) : null;

  const activeDeals   = deals.filter(d => !['won','lost'].includes(d.status));
  const pipeline      = activeDeals.reduce((s, d) => s + (Number(d.amount) || 0), 0);
  const relancesDues  = activeDeals.filter(d => d.date_relance && d.date_relance <= t).length;

  const totalClosed   = deals.filter(d => ['won','lost'].includes(d.status)).length;
  const totalWon      = deals.filter(d => d.status === 'won').length;
  const txConv        = totalClosed > 0 ? Math.round(totalWon / totalClosed * 100) : 0;

  /* Délai moyen de closing (jours entre created_at et updated_at pour les won) */
  const wonDeals = deals.filter(d => d.status === 'won' && d.created_at && d.updated_at);
  const avgClosing = wonDeals.length > 0
    ? Math.round(wonDeals.reduce((s, d) => {
        const ms = new Date(d.updated_at) - new Date(d.created_at);
        return s + ms / 86_400_000;
      }, 0) / wonDeals.length)
    : null;

  /* Devis en attente (sent / negotiating) */
  const pendingQuotes  = quotes.filter(q => ['sent','negotiating'].includes(q.status));
  const pendingQuoteAmt= pendingQuotes.reduce((s, q) => s + (Number(q.total_ttc) || 0), 0);

  return {
    wonCur, trendPct, trend: { cur: wonCur, prev: wonPrev, pct: trendPct },
    pipeline, pipelineNb: activeDeals.length,
    relancesDues,
    txConv, totalWon, totalClosed,
    avgClosing,
    pendingQuoteAmt, pendingQuoteNb: pendingQuotes.length,
  };
}

