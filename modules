/* ────────────────────────────────────────────────────────────────
   MODIFIER CATÉGORIE
──────────────────────────────────────────────────────────────── */
async function editFileCategory(fileId) {
  const file = _mediaFiles.find(f => f.id === fileId);
  if (!file) return;

  const cats    = Object.entries(CATEGORY_LABELS);
  const options = cats.map(([k, v]) => `${k}: ${v.label}`).join('\n');
  const current = file.category;
  const input   = prompt(
    `Changer la catégorie de "${file.name}".\nOptions :\n${options}\n\nCatégorie actuelle : ${current}`,
    current
  );

  if (!input || input === current) return;
  const key = input.trim().toLowerCase();
  if (!CATEGORY_LABELS[key]) {
    showToast('Catégorie invalide', 'error'); return;
  }

  const { error } = await _sb.from('files').update({ category: key }).eq('id', fileId);
  if (error) { showToast('Erreur : ' + error.message, 'error'); return; }

  showToast('Catégorie mise à jour', 'success');
  _mediaFiles = await _fetchFiles();
  _rebuildMediatheque();
}

/* ────────────────────────────────────────────────────────────────
   SUPPRIMER
──────────────────────────────────────────────────────────────── */
async function deleteMediaFile(fileId) {
  const file = _mediaFiles.find(f => f.id === fileId);
  if (!file) return;

  confirmAction(`Supprimer définitivement "${file.name}" ?`, async () => {
    try {
      /* 1. Supprimer du storage */
      await _sb.storage.from('crm-files').remove([file.storage_path]);
      /* 2. Supprimer de la BDD */
      const { error } = await _sb.from('files').delete().eq('id', fileId);
      if (error) throw new Error(error.message);

      showToast('Fichier supprimé', 'success');
      _mediaFiles = _mediaFiles.filter(f => f.id !== fileId);
      _rebuildMediatheque();
    } catch (e) {
      showToast('Erreur suppression : ' + e.message, 'error');
    }
  });
}

