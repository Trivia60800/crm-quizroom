   GÉNÉRATION IA
──────────────────────────────────────────────────────────────── */
async function generateEmailDraft() {
  const ctx = _composeContext || {};
  if (!_composeTo.length && !ctx.company_name) {
    showToast('Sélectionnez d\'abord un destinataire pour un brouillon adapté', 'info');
    return;
  }

  const aiStatus = document.getElementById('compose-ai-status');
  if (aiStatus) aiStatus.style.display = 'flex';

  try {
    const company = ctx.company_name || (_composeTo[0]?.name || 'le prospect');
    const result  = await generateEmailScript({
      name:        company,
      sector:      ctx.sector       || null,
      city:        ctx.city         || 'Amiens',
      ai_analysis: {
        type_cible:      ctx.sector      || null,
        angle_approche:  ctx.last_note   || null,
      },
    });

    if (result?.subject) {
      const subj = document.getElementById('compose-subject');
      if (subj && !subj.value) subj.value = result.subject;
    }
    if (result?.body) {
      const body = document.getElementById('compose-body');
      if (body) body.innerHTML = result.body.replace(/\n/g, '<br>');
    }
  } catch (e) {
    showToast('Erreur IA : ' + e.message, 'error');
  } finally {
    if (aiStatus) aiStatus.style.display = 'none';
  }
}

async function _suggestSubject() {
  const body = document.getElementById('compose-body')?.innerText?.trim();
  if (!body && !_composeTo.length) { showToast('Ajoutez du contenu pour suggérer un objet', 'info'); return; }

  const aiStatus = document.getElementById('compose-ai-status');
  if (aiStatus) aiStatus.style.display = 'flex';

  try {
    const prompt = `Propose UN objet d'email accrocheur (max 60 caractères) pour ce contexte :
${_composeTo.length ? `Destinataire : ${_composeTo[0].name}` : ''}
${body ? `Contenu : ${body.substring(0, 200)}` : ''}
Réponds avec l'objet UNIQUEMENT, sans guillemets.`;
    const raw    = await callClaude(prompt, 100);
    const subjEl = document.getElementById('compose-subject');
    if (subjEl) subjEl.value = raw.trim().replace(/^"(.+)"$/, '$1');
  } catch (e) {
    showToast('Erreur IA : ' + e.message, 'error');
  } finally {
    if (aiStatus) aiStatus.style.display = 'none';
  }
}

