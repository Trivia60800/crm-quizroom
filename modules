/* ────────────────────────────────────────────────────────────────
   HELPERS LOCAUX
──────────────────────────────────────────────────────────────── */
function _getLast12Months() {
  const now    = new Date();
  const months = [];
  const MOIS   = ['Jan','Fév','Mar','Avr','Mai','Jun','Jul','Aoû','Sep','Oct','Nov','Déc'];
  for (let i = 11; i >= 0; i--) {
    const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
    months.push({
      key:   `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`,
      label: `${MOIS[d.getMonth()]} ${String(d.getFullYear()).slice(2)}`,
    });
  }
  return months;
}

function _daysDiff(dateStr) {
  try {
    return Math.round((new Date(dateStr + 'T12:00:00') - new Date()) / 86_400_000);
  } catch { return 0; }
}

function _fmtE(v) {
  if (!v) return '0 €';
  return Number(v).toLocaleString('fr-FR', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 });
}

function _esc(s) {
  if (!s) return '';
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

'use strict';
/* ================================================================
   modules/companies.js — Quiz Room CRM · Phase 5
   Liste entreprises · Fiche détaillée · Contacts · Timeline
================================================================ */

/* ────────────────────────────────────────────────────────────────
   STATE
──────────────────────────────────────────────────────────────── */
let _companiesAll    = [];
let _companiesView   = 'grid';     // 'grid' | 'list'
let _compSearch      = '';
let _compSectorFilter= '';
let _compSourceFilter= '';
let _currentDetailId = null;
let _currentDetailCompany = null;
let _currentDetailTab= 'apercu';

/* ────────────────────────────────────────────────────────────────
   RENDER ENTRY POINT
──────────────────────────────────────────────────────────────── */
async function renderCompanies() {
  const content = document.getElementById('app-content');
  if (!content) return;
  content.innerHTML = `<div class="page-loading"><div class="spinner"></div><p>Chargement…</p></div>`;
  _companiesAll = await fetchCompanies();
  _compSearch = '';
  _buildCompaniesView();
}

/* ────────────────────────────────────────────────────────────────
   LISTE PRINCIPALE
──────────────────────────────────────────────────────────────── */
function _buildCompaniesView() {
  const content = document.getElementById('app-content');
  if (!content) return;

  const filtered = _applyCompanyFilters(_companiesAll);

  content.innerHTML = `
    <div class="companies-container">
      <div class="companies-toolbar">
        <div class="search-wrap" style="min-width:220px">
          <i class="fa-solid fa-magnifying-glass"></i>
          <input type="text" id="companies-search" placeholder="Rechercher une entreprise…"
            value="${_esc(_compSearch)}"
            oninput="filterCompanies()">
        </div>
        <div class="companies-filters">
          <select id="companies-sector-filter" onchange="filterCompanies()">
            <option value="">Tous secteurs</option>
            ${['CSE','Entreprise','Association','École','Collectivité','Agence','Hôtel','Autre']
               .map(s => `<option value="${s}" ${_compSectorFilter===s?'selected':''}>${s}</option>`).join('')}
          </select>
          <select id="companies-source-filter" onchange="filterCompanies()">
            <option value="">Toutes sources</option>
            <option value="prospection" ${_compSourceFilter==='prospection'?'selected':''}>Prospection</option>
            <option value="csv"         ${_compSourceFilter==='csv'?'selected':''}>Import CSV</option>
            <option value="manual"      ${_compSourceFilter==='manual'?'selected':''}>Manuel</option>
            <option value="inbound"     ${_compSourceFilter==='inbound'?'selected':''}>Entrant</option>
          </select>
        </div>
        <div class="view-toggle">
          <button class="view-btn ${_companiesView==='grid'?'active':''}" onclick="setCompaniesView('grid')" title="Grille">
            <i class="fa-solid fa-grip"></i>
          </button>
          <button class="view-btn ${_companiesView==='list'?'active':''}" onclick="setCompaniesView('list')" title="Liste">
            <i class="fa-solid fa-list"></i>
          </button>
        </div>
        <button class="btn btn-primary" onclick="openAddCompanyModal()">
          <i class="fa-solid fa-plus"></i> Nouvelle entreprise
        </button>
      </div>

      <div class="companies-count" id="companies-count">
        <strong>${filtered.length}</strong> entreprise${filtered.length!==1?'s':''}
        ${filtered.length < _companiesAll.length ? ` sur ${_companiesAll.length}` : ''}
      </div>

      ${_companiesView === 'grid'
        ? `<div class="companies-grid" id="companies-grid">
             ${filtered.length ? filtered.map(c => _renderCompanyCard(c)).join('') : _emptyState('Aucune entreprise', 'fa-building')}
           </div>`
        : `<div class="companies-list-wrap">
             <table class="list-table">
               <thead><tr>
                 <th>Entreprise</th><th>Secteur</th><th>Ville</th>
                 <th>Score IA</th><th>Source</th><th>Actions</th>
               </tr></thead>
               <tbody id="companies-list-tbody">
                 ${filtered.map(_renderCompanyRow).join('') || `<tr><td colspan="6">${_emptyState('Aucune entreprise', 'fa-building')}</td></tr>`}
               </tbody>
             </table>
           </div>`
      }
    </div>`;

  _injectCompanyModal();
  _injectContactModal();
}

function filterCompanies() {
  _compSearch       = document.getElementById('companies-search')?.value?.trim().toLowerCase() || '';
  _compSectorFilter = document.getElementById('companies-sector-filter')?.value || '';
  _compSourceFilter = document.getElementById('companies-source-filter')?.value || '';
  _buildCompaniesView();
}

function setCompaniesView(v) {
  _companiesView = v;
  _buildCompaniesView();
}

function _applyCompanyFilters(list) {
  return list.filter(c => {
    if (_compSearch && !(`${c.name} ${c.city||''} ${c.sector||''}`).toLowerCase().includes(_compSearch)) return false;
    if (_compSectorFilter && c.sector !== _compSectorFilter) return false;
    if (_compSourceFilter && c.source !== _compSourceFilter) return false;
    return true;
  });
}

/* ────────────────────────────────────────────────────────────────
   CARD GRILLE
──────────────────────────────────────────────────────────────── */
function _renderCompanyCard(company) {
  const color    = _stringToColor(company.name);
  const initials = company.name.split(/\s+/).slice(0,2).map(w=>w[0]||'').join('').toUpperCase() || '?';
  const score    = company.ai_score || 0;
  const tags     = Array.isArray(company.tags) ? company.tags : [];

  return `
    <div class="company-card" onclick="openCompanyDetail(${company.id})">
      <div class="company-card-header">
        <div class="company-avatar" style="background:${color}18;color:${color}">${initials}</div>
        <div class="company-card-info">
          <div class="company-card-name">${_esc(company.name)}</div>
          <div class="company-card-sector muted">${_esc(company.sector||'—')}</div>
        </div>
        ${score > 0 ? `<div class="ai-score-mini" title="Score IA ${score}/100">
          <div class="ai-score-track"><div class="ai-score-fill" style="width:${score}%"></div></div>
          <span>${score}</span>
        </div>` : ''}
      </div>
      <div class="company-card-meta">
        ${company.city  ? `<span><i class="fa-solid fa-location-dot"></i> ${_esc(company.city)}</span>` : ''}
        ${company.phone ? `<span><i class="fa-solid fa-phone"></i> ${_esc(company.phone)}</span>` : ''}
      </div>
      <div class="company-card-footer">
        <div class="company-card-tags">
          ${tags.slice(0,2).map(t=>`<span class="tag-chip">${_esc(t)}</span>`).join('')}
          ${company.source ? `<span class="source-chip">${_esc(company.source)}</span>` : ''}
        </div>
      </div>
    </div>`;
}

function _renderCompanyRow(company) {
  const score = company.ai_score || 0;
  return `
    <tr class="table-row-link" onclick="openCompanyDetail(${company.id})">
      <td><strong>${_esc(company.name)}</strong></td>
      <td>${_esc(company.sector||'—')}</td>
      <td>${_esc(company.city||'—')}</td>
      <td>
        ${score > 0
          ? `<div style="display:flex;align-items:center;gap:6px">
               <div class="ai-score-track" style="width:60px"><div class="ai-score-fill" style="width:${score}%"></div></div>
               <span style="font-size:.75rem">${score}</span>
             </div>`
          : '<span class="muted">—</span>'}
      </td>
      <td>${company.source ? `<span class="source-chip">${_esc(company.source)}</span>` : '—'}</td>
      <td onclick="event.stopPropagation()" style="white-space:nowrap">
        <button class="btn-icon" title="Modifier" onclick="openEditCompanyModal(${company.id})">
          <i class="fa-solid fa-pen"></i>
        </button>
        <button class="btn-icon" style="color:var(--urgent)" title="Supprimer" onclick="_confirmDeleteCompany(${company.id})">
          <i class="fa-solid fa-trash"></i>
        </button>
      </td>
    </tr>`;
}

/* ────────────────────────────────────────────────────────────────
   FICHE DÉTAILLÉE
──────────────────────────────────────────────────────────────── */
async function openCompanyDetail(companyId) {
  const content = document.getElementById('app-content');
  if (!content) return;

  _currentDetailId  = companyId;
  content.innerHTML = `<div class="page-loading"><div class="spinner"></div><p>Chargement de la fiche…</p></div>`;

  const [company, deals, contacts, activities, quotes] = await Promise.all([
    fetchCompanyById(companyId),
    _sb.from('deals').select('*').eq('company_id', companyId).order('created_at', { ascending: false }),
    fetchContacts(companyId),
    fetchActivities({ company_id: companyId, limit: 100 }),
    _sb.from('quotes').select('*').eq('company_id', companyId).order('created_at', { ascending: false }),
  ]);

  if (!company) { showToast('Entreprise introuvable', 'error'); navigate('companies'); return; }

  _currentDetailCompany = company;
  const dealsData   = deals.data  || [];
  const quotesData  = quotes.data || [];

  const color    = _stringToColor(company.name);
  const initials = company.name.split(/\s+/).slice(0,2).map(w=>w[0]||'').join('').toUpperCase() || '?';
  const lastAct  = activities?.[0]?.created_at || null;
  const reactiv  = _getReactivity(lastAct);
  const ai       = company.notes?.startsWith('[IA]') ? null : null; // placeholder

  content.innerHTML = `
    <div class="company-detail-view">

      <!-- Breadcrumb -->
      <div class="breadcrumb">
        <button class="btn-link" onclick="navigate('companies')">
          <i class="fa-solid fa-arrow-left"></i> Entreprises
        </button>
        <span class="bc-sep">›</span>
        <span>${_esc(company.name)}</span>
      </div>

      <!-- Header -->
      <div class="company-detail-header">
        <div class="company-avatar lg" style="background:${color}18;color:${color}">${initials}</div>
        <div class="company-detail-main">
          <h1>${_esc(company.name)}</h1>
          <div class="company-detail-meta">
            ${company.sector  ? `<span><i class="fa-solid fa-tag"></i> ${_esc(company.sector)}</span>` : ''}
            ${company.city    ? `<span><i class="fa-solid fa-location-dot"></i> ${_esc(company.city)}</span>` : ''}
            ${company.phone   ? `<a href="tel:${_esc(company.phone)}"><i class="fa-solid fa-phone"></i> ${_esc(company.phone)}</a>` : ''}
            ${company.website ? `<a href="${_esc(company.website)}" target="_blank" rel="noopener"><i class="fa-solid fa-globe"></i> Site web</a>` : ''}
          </div>
          <div class="company-detail-tags">
            <span class="reactivity-badge ${reactiv.cls}">
              <span class="reactivity-dot ${reactiv.cls}"></span> ${reactiv.label}
            </span>
            ${company.source ? `<span class="source-chip">${_esc(company.source)}</span>` : ''}
            ${(Array.isArray(company.tags)?company.tags:[]).map(t=>`<span class="tag-chip">${_esc(t)}</span>`).join('')}
          </div>
        </div>
        <div class="company-detail-actions">
          <button class="btn btn-primary btn-sm" onclick="openComposeEmail({company_id:${company.id},company_name:'${_esc(company.name)}',to:'${_esc(company.email||'')}',sector:'${_esc(company.sector||'')}' })">
            <i class="fa-solid fa-envelope"></i> Email
          </button>
          <button class="btn btn-secondary btn-sm" onclick="openAddModal()">
            <i class="fa-solid fa-plus"></i> Deal
          </button>
          <button class="btn btn-secondary btn-sm" onclick="openScriptPanel(_currentDetailCompany,'email')">
            <i class="fa-solid fa-wand-magic-sparkles"></i> Script IA
          </button>
          <button class="btn-icon" onclick="openEditCompanyModal(${company.id})" title="Modifier">
            <i class="fa-solid fa-pen"></i>
          </button>
        </div>
      </div>

      ${company.ai_score > 0 ? `
      <div class="ai-analysis-card">
        <div class="ai-card-header">
          <i class="fa-solid fa-wand-magic-sparkles" style="color:var(--accent)"></i>
          Score de pertinence IA
        </div>
        <div class="ai-card-body">
          <div style="display:flex;align-items:center;gap:12px">
            <div class="ai-score-track" style="flex:1;height:8px">
              <div class="ai-score-fill" style="width:${company.ai_score}%;background:var(--accent)"></div>
            </div>
            <strong>${company.ai_score}/100</strong>
          </div>
          ${company.notes && !company.notes.startsWith('[IA]') ? `<p style="margin-top:8px;font-size:.83rem;color:var(--muted)">${_esc(company.notes)}</p>` : ''}
        </div>
      </div>` : ''}

      <!-- Onglets -->
      <div class="detail-tabs" id="detail-tabs">
        ${_detailTabBtn('apercu',    'fa-house',             'Aperçu',     null,                 _currentDetailTab)}
        ${_detailTabBtn('contacts',  'fa-users',             'Contacts',   contacts.length,      _currentDetailTab)}
        ${_detailTabBtn('deals',     'fa-table-columns',     'Deals',      dealsData.length,     _currentDetailTab)}
        ${_detailTabBtn('devis',     'fa-file-invoice-dollar','Devis',     quotesData.length,    _currentDetailTab)}
        ${_detailTabBtn('activites', 'fa-clock-rotate-left', 'Activités',  activities.length,    _currentDetailTab)}
        ${_detailTabBtn('notes',     'fa-note-sticky',       'Notes',      null,                 _currentDetailTab)}
      </div>

      <div id="detail-tab-content"></div>
    </div>`;

  _injectCompanyModal();
  _injectContactModal();

  /* Listener onglets */
  content.querySelectorAll('.detail-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      content.querySelectorAll('.detail-tab').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      _currentDetailTab = btn.dataset.tab;
      _renderDetailTab(btn.dataset.tab, { company, dealsData, contacts, activities, quotesData });
    });
  });

  _renderDetailTab(_currentDetailTab, { company, dealsData, contacts, activities, quotesData });
}

function _detailTabBtn(tab, icon, label, count, active) {
  return `<button class="detail-tab ${active===tab?'active':''}" data-tab="${tab}">
    <i class="fa-solid ${icon}"></i> ${label}
    ${count !== null ? `<span class="cnt">${count}</span>` : ''}
  </button>`;
}

function _renderDetailTab(tab, { company, dealsData, contacts, activities, quotesData }) {
  const container = document.getElementById('detail-tab-content');
  if (!container) return;

  switch (tab) {
    case 'apercu':    container.innerHTML = _renderApercu(company, dealsData, contacts, activities); break;
    case 'contacts':  container.innerHTML = _renderContactsTab(company.id, contacts); break;
    case 'deals':     container.innerHTML = _renderDealsTab(dealsData); break;
    case 'devis':     container.innerHTML = _renderDevisTab(quotesData); break;
    case 'activites': container.innerHTML = _renderActivitiesTab(activities); break;
    case 'notes':     container.innerHTML = _renderNotesTab(company.id, activities.filter(a=>a.type==='note')); break;
  }
}

/* ── Onglet Aperçu ─────────────────────────────────────────── */
function _renderApercu(company, deals, contacts, activities) {
  const totalPipeline = deals.filter(d=>!['won','lost'].includes(d.status))
    .reduce((s,d)=>s+(d.amount||0),0);
  const totalWon = deals.filter(d=>d.status==='won').reduce((s,d)=>s+(d.amount||0),0);
  const lastAct  = activities[0];

  return `
    <div class="tab-panel">
      <div class="apercu-stats">
        <div class="apercu-stat"><div class="apercu-stat-v">${contacts.length}</div><div class="apercu-stat-l">Contacts</div></div>
        <div class="apercu-stat"><div class="apercu-stat-v">${deals.length}</div><div class="apercu-stat-l">Deals</div></div>
        <div class="apercu-stat"><div class="apercu-stat-v" style="color:var(--accent)">${_fmtE(totalPipeline)}</div><div class="apercu-stat-l">Pipeline</div></div>
        <div class="apercu-stat"><div class="apercu-stat-v" style="color:var(--won)">${_fmtE(totalWon)}</div><div class="apercu-stat-l">Gagné</div></div>
        <div class="apercu-stat"><div class="apercu-stat-v">${activities.length}</div><div class="apercu-stat-l">Activités</div></div>
      </div>

      <div class="apercu-grid">
        <div class="apercu-block">
          <div class="apercu-block-title">Informations</div>
          ${company.email   ? `<div class="apercu-row"><i class="fa-solid fa-envelope"></i><a href="mailto:${_esc(company.email)}">${_esc(company.email)}</a></div>` : ''}
          ${company.address ? `<div class="apercu-row"><i class="fa-solid fa-location-dot"></i>${_esc(company.address)}</div>` : ''}
          ${company.website ? `<div class="apercu-row"><i class="fa-solid fa-globe"></i><a href="${_esc(company.website)}" target="_blank" rel="noopener">${_esc(company.website)}</a></div>` : ''}
          ${company.source  ? `<div class="apercu-row"><i class="fa-solid fa-arrow-right-to-bracket"></i>Source : ${_esc(company.source)}</div>` : ''}
        </div>
        <div class="apercu-block">
          <div class="apercu-block-title">Dernière activité</div>
          ${lastAct ? `
            <div class="apercu-last-act">
              <span class="timeline-badge">${_esc(lastAct.type)}</span>
              <strong>${_esc(lastAct.title||lastAct.type)}</strong>
              <span class="muted">${timeAgo(lastAct.created_at)}</span>
            </div>` : '<div class="muted">Aucune activité</div>'}
        </div>
      </div>
    </div>`;
}

/* ── Onglet Contacts ───────────────────────────────────────── */
function _renderContactsTab(companyId, contacts) {
  return `
    <div class="tab-panel">
      <div style="display:flex;justify-content:flex-end;margin-bottom:16px">
        <button class="btn btn-primary btn-sm" onclick="openAddContactModal(${companyId})">
          <i class="fa-solid fa-plus"></i> Ajouter un contact
        </button>
      </div>
      <div class="contacts-grid">
        ${contacts.map(_renderContactCard).join('')}
        ${!contacts.length ? _emptyState('Aucun contact', 'fa-user') : ''}
      </div>
    </div>`;
}

function _renderContactCard(contact) {
  const initials = `${(contact.first_name||'')[0]||''}${(contact.last_name||'')[0]||''}`.toUpperCase();
  return `
    <div class="contact-card">
      <div class="contact-avatar">${initials||'?'}</div>
      <div class="contact-info">
        <div class="contact-name">${_esc(contact.first_name||'')} ${_esc(contact.last_name||'')}</div>
        <div class="contact-title muted">${_esc(contact.job_title||'—')}</div>
        <div class="contact-reach">
          ${contact.email ? `<a href="mailto:${_esc(contact.email)}" onclick="event.stopPropagation()">
            <i class="fa-solid fa-envelope"></i> ${_esc(contact.email)}</a>` : ''}
          ${contact.phone ? `<a href="tel:${_esc(contact.phone)}" onclick="event.stopPropagation()">
            <i class="fa-solid fa-phone"></i> ${_esc(contact.phone)}</a>` : ''}
        </div>
      </div>
      <div class="contact-actions">
        ${contact.email ? `<button class="btn btn-primary btn-sm"
          onclick="event.stopPropagation();openComposeEmail({to:'${_esc(contact.email)}',contact_id:${contact.id}})">
          <i class="fa-solid fa-envelope"></i> Email
        </button>` : ''}
        <button class="btn btn-secondary btn-sm"
          onclick="event.stopPropagation();_logCallUI(${contact.id},'${_esc(contact.first_name||'')} ${_esc(contact.last_name||'')}')">
          <i class="fa-solid fa-phone"></i> Appel
        </button>
        <button class="btn-icon" style="color:var(--urgent)"
          onclick="event.stopPropagation();_confirmDeleteContact(${contact.id})">
          <i class="fa-solid fa-trash"></i>
        </button>
      </div>
    </div>`;
}

/* ── Onglet Deals ──────────────────────────────────────────── */
function _renderDealsTab(deals) {
  if (!deals.length) return `<div class="tab-panel">${_emptyState('Aucun deal','fa-table-columns')}</div>`;
  const STATUS = { new:'Nouveau', progress:'En cours', urgent:'À relancer', won:'Gagné', lost:'Perdu' };
  return `
    <div class="tab-panel">
      <table class="list-table">
        <thead><tr><th>Deal</th><th>Montant</th><th>Statut</th><th>Relance</th><th>Date</th></tr></thead>
        <tbody>
          ${deals.map(d => `
            <tr class="table-row-link" onclick="openDealModal(${d.id})">
              <td><strong>${_esc(d.title||'Sans titre')}</strong></td>
              <td>${_fmtE(d.amount)}</td>
              <td><span class="status-pill status-${d.status}">${STATUS[d.status]||d.status}</span></td>
              <td class="${d.date_relance && d.date_relance < today() ? 'text-urgent' : ''}">${d.date_relance||'—'}</td>
              <td class="muted">${formatDate(d.created_at)}</td>
            </tr>`).join('')}
        </tbody>
      </table>
    </div>`;
}

/* ── Onglet Devis ──────────────────────────────────────────── */
function _renderDevisTab(quotes) {
  if (!quotes.length) return `<div class="tab-panel">${_emptyState('Aucun devis','fa-file-invoice-dollar')}</div>`;
  const STATUS = { draft:'Brouillon', sent:'Envoyé', signed:'Signé', refused:'Refusé', negotiating:'Négociation' };
  return `
    <div class="tab-panel">
      <table class="list-table">
        <thead><tr><th>N° Devis</th><th>Total TTC</th><th>Statut</th><th>Valide jusqu'au</th><th>Actions</th></tr></thead>
        <tbody>
          ${quotes.map(q => `
            <tr class="table-row-link" onclick="openQuoteModal(${q.id})">
              <td><span class="quote-number-badge">${_esc(q.quote_number)}</span></td>
              <td><strong>${_fmtE(q.total_ttc)}</strong></td>
              <td>${STATUS[q.status]||q.status}</td>
              <td>${formatDate(q.valid_until)}</td>
              <td onclick="event.stopPropagation()">
                <button class="btn-icon" title="PDF" onclick="downloadQuotePDF(${q.id})">
                  <i class="fa-solid fa-file-pdf"></i>
                </button>
              </td>
            </tr>`).join('')}
        </tbody>
      </table>
    </div>`;
}

/* ── Onglet Activités — Timeline ───────────────────────────── */
function _renderActivitiesTab(activities) {
  const ICONS = {
    email:         { icon:'fa-envelope',               color:'--accent'   },
    call:          { icon:'fa-phone',                  color:'--progress' },
    note:          { icon:'fa-note-sticky',            color:'--warning'  },
    status_change: { icon:'fa-arrow-right-arrow-left', color:'--muted'    },
    relance:       { icon:'fa-bell',                   color:'--urgent'   },
    quote_sent:    { icon:'fa-paper-plane',            color:'--progress' },
    quote_signed:  { icon:'fa-file-signature',         color:'--won'      },
    quote_created: { icon:'fa-file-invoice-dollar',    color:'--accent'   },
    create:        { icon:'fa-circle-plus',            color:'--won'      },
  };

  if (!activities.length) return `
    <div class="tab-panel"><div class="empty-state-sm">
      <i class="fa-solid fa-clock-rotate-left"></i> Aucune activité
    </div></div>`;

  return `
    <div class="tab-panel">
      <div class="activity-timeline">
        ${activities.map(a => {
          const cfg = ICONS[a.type] || ICONS.note;
          const meta = a.metadata || {};
          return `
            <div class="timeline-item">
              <div class="timeline-dot" style="background:var(${cfg.color})">
                <i class="fa-solid ${cfg.icon}"></i>
              </div>
              <div class="timeline-content">
                <div class="timeline-header">
                  <span class="timeline-title">${_esc(a.title||a.type)}</span>
                  <span class="timeline-date muted">${timeAgo(a.created_at)}</span>
                </div>
                ${a.body ? `<div class="timeline-body">${_esc(a.body.substring(0,200))}</div>` : ''}
                ${meta.attachments?.length ? `<div class="timeline-attachments">
                  <i class="fa-solid fa-paperclip"></i> ${meta.attachments.join(', ')}</div>` : ''}
              </div>
            </div>`;
        }).join('')}
      </div>
    </div>`;
}

