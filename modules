/* ────────────────────────────────────────────────────────────────
   HELPERS LOCAUX
──────────────────────────────────────────────────────────────── */
function _esc(s) {
  if (!s) return '';
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function _fmtE(v) {
  if (!v) return '—';
  return Number(v).toLocaleString('fr-FR',{style:'currency',currency:'EUR',maximumFractionDigits:0});
}
function _stringToColor(str) {
  let h = 0;
  for (let i = 0; i < str.length; i++) h = str.charCodeAt(i) + ((h << 5) - h);
  return `hsl(${((h % 360) + 360) % 360},60%,45%)`;
}
function _getReactivity(dateStr) {
  if (!dateStr) return { cls:'cold', label:'Jamais contacté' };
  try {
    const days = Math.abs(Math.round((new Date() - new Date(dateStr)) / 86_400_000));
    if (days <= 7)  return { cls:'hot',  label:`Actif il y a ${days}j` };
    if (days <= 30) return { cls:'warm', label:`Actif il y a ${days}j` };
    return               { cls:'cold', label:`Inactif depuis ${days}j` };
  } catch { return { cls:'cold', label:'—' }; }
}
function _emptyState(label, icon) {
  return `<div class="empty-state" style="min-height:200px">
    <i class="fa-solid ${icon} empty-icon"></i>
    <div class="empty-title">${label}</div>
  </div>`;
}
