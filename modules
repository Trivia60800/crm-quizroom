/* ────────────────────────────────────────────────────────────────
   OUVRIR / FERMER MODAL DEVIS
──────────────────────────────────────────────────────────────── */
async function openQuoteModal(id = null) {
  _injectQuoteModal();
  _injectCatalogueModal();

  _currentQuoteId     = id;
  _currentQuote       = null;
  _currentQuoteNumber = null;
  _currentQuoteLines  = [];

  /* Pré-remplir listes */
  _fillCompanySelect('qf-company', _allCompaniesQ);

  if (id) {
    /* Mode édition */
    document.getElementById('quote-modal-title').textContent = 'Modifier le devis';
    document.getElementById('btn-delete-quote').style.display = '';

    const { data } = await _sb
      .from('quotes')
      .select('*')
      .eq('id', id)
      .single();

    if (!data) { showToast('Devis introuvable', 'error'); return; }
    _currentQuote       = data;
    _currentQuoteNumber = data.quote_number;
    _currentQuoteLines  = Array.isArray(data.lines)
      ? data.lines
      : (data.lines ? JSON.parse(data.lines) : []);

    document.getElementById('quote-number-display').textContent = data.quote_number;
    document.getElementById('qf-company').value        = data.company_id     || '';
    document.getElementById('qf-company-free').value   = '';
    document.getElementById('qf-date').value           = (data.created_at || '').split('T')[0];
    document.getElementById('qf-valid-until').value    = data.valid_until    || '';
    document.getElementById('qf-discount').value       = data.discount_global || 0;
    document.getElementById('qf-status').value         = data.status         || 'draft';
    document.getElementById('qf-notes').value          = data.notes          || '';

    await loadContactsForQuote(data.contact_id);

  } else {
    /* Mode création */
    document.getElementById('quote-modal-title').textContent = 'Nouveau devis';
    document.getElementById('btn-delete-quote').style.display = 'none';
    document.getElementById('quote-number-display').textContent = '';
    document.getElementById('qf-company').value = '';
    document.getElementById('qf-company-free').value = '';
    document.getElementById('qf-contact').innerHTML = '<option value="">— Sélectionner un contact —</option>';
    document.getElementById('qf-date').value = today();
    // Valide 30 jours par défaut
    const valid = new Date(); valid.setDate(valid.getDate() + 30);
    document.getElementById('qf-valid-until').value = valid.toISOString().split('T')[0];
    document.getElementById('qf-discount').value    = 0;
    document.getElementById('qf-status').value      = 'draft';
    document.getElementById('qf-notes').value       = '';
    addQuoteLine(); // une ligne vide par défaut
  }

  _renderAllQuoteLines();
  recalcQuote();
  openModal('quote-modal');
}

function closeQuoteModal() {
  closeModal('quote-modal');
  _currentQuoteId     = null;
  _currentQuote       = null;
  _currentQuoteLines  = [];
}

function openAddQuoteModal() { openQuoteModal(); }

function _onStatusChange(status) {
  /* Si on passe à "sent" et le devis n'a pas encore été envoyé → pré-remplir sent_at */
  if (status === 'sent' && _currentQuote && !_currentQuote.sent_at) {
    showToast('La date d\'envoi sera enregistrée automatiquement', 'info');
