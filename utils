/* ────────────────────────────────────────────────────────────────
   DATE & AMOUNT FORMATTERS
──────────────────────────────────────────────────────────────── */
function today() {
  return new Date().toISOString().split('T')[0];
}

function formatDate(dateStr) {
  if (!dateStr) return '—';
  try {
    const d = new Date(dateStr.includes('T') ? dateStr : dateStr + 'T00:00:00');
    return d.toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: 'numeric' });
  } catch { return dateStr; }
}

function formatDateShort(dateStr) {
  if (!dateStr) return '—';
  try {
    const d = new Date(dateStr.includes('T') ? dateStr : dateStr + 'T00:00:00');
    return d.toLocaleDateString('fr-FR', { day: '2-digit', month: 'short' });
  } catch { return dateStr; }
}

function formatAmount(amount) {
  if (amount === null || amount === undefined || amount === '') return '—';
  return Number(amount).toLocaleString('fr-FR', {
    style: 'currency', currency: 'EUR', maximumFractionDigits: 0
  });
}

function daysUntil(dateStr) {
  if (!dateStr) return null;
  const now    = new Date(); now.setHours(0, 0, 0, 0);
  const target = new Date(dateStr + 'T00:00:00');
  return Math.round((target - now) / 86_400_000);
}

function isOverdue(dateStr) {
  if (!dateStr) return false;
  return daysUntil(dateStr) < 0;
}

function timeAgo(dateStr) {
  if (!dateStr) return '';
  const d    = Math.round((Date.now() - new Date(dateStr)) / 60_000); // minutes
  if (d < 2)   return "à l'instant";
  if (d < 60)  return `il y a ${d} min`;
  if (d < 1440) return `il y a ${Math.round(d/60)}h`;
  return `il y a ${Math.round(d/1440)}j`;
}

/* ────────────────────────────────────────────────────────────────
   FORM HELPERS
──────────────────────────────────────────────────────────────── */
function getFormData(formId) {
  const form = document.getElementById(formId);
  if (!form) return {};
  const out = {};
  form.querySelectorAll('[name]').forEach(el => {
    const v = el.value.trim();
    if (el.type === 'number')   out[el.name] = v === '' ? null : (Number(v) || null);
    else if (v === '')          out[el.name] = null;
    else                        out[el.name] = v;
  });
  return out;
}

function setFormData(formId, obj) {
  if (!obj) return;
  const form = document.getElementById(formId);
  if (!form) return;
  Object.entries(obj).forEach(([key, val]) => {
    const el = form.querySelector(`[name="${key}"]`);
    if (el) el.value = val ?? '';
  });
}

function clearForm(formId) {
  const form = document.getElementById(formId);
  if (form) form.reset();
}

