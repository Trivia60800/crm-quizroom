function _gmailCfg() {
  return {
    CLIENT_ID:    CONFIG?.GMAIL_CLIENT_ID    || '',
    REDIRECT_URI: window.location.origin + '/oauth-callback.html',
    SCOPES: [
      'https://www.googleapis.com/auth/gmail.send',
