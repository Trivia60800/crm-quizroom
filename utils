  try {
    /* ⚠️  En production : envoyer ce code vers une Edge Function Supabase
       qui détient le CLIENT_SECRET et fait l'échange serveur-side.
       En usage interne mono-utilisateur, on peut utiliser PKCE ou un proxy
       Netlify Function léger.

       Pour simplifier, on stocke un "pending code" et on affiche les instructions. */
    await setSetting('gmail_auth_pending_code', code);
    hideLoader();
    showToast(
      'Code OAuth reçu. Configurez votre Edge Function pour finaliser.',
      'info'
    );

    // Si une fonction de token-exchange est définie (proxy externe), l'utiliser
    if (typeof window._gmailExchangeCode === 'function') {
      const tokenData = await window._gmailExchangeCode(code);
      if (tokenData) await _saveTokens(tokenData);
    }
  } catch (e) {
    hideLoader();
    showToast('Erreur connexion Gmail : ' + e.message, 'error');
  }
}

async function _saveTokens({ access_token, refresh_token, expires_in, email }) {
  await Promise.all([
    setSetting('gmail_access_token',  access_token),
    setSetting('gmail_refresh_token', refresh_token || ''),
    setSetting('gmail_email',         email || ''),
    setSetting('gmail_token_expiry',  String(Date.now() + (expires_in || 3600) * 1000)),
  ]);
  showToast('Gmail connecté ✓', 'success');
}

/* ────────────────────────────────────────────────────────────────
   LECTURE TOKEN
──────────────────────────────────────────────────────────────── */
async function getGmailStatus() {
  const { data } = await _sb
    .from('settings')
    .select('key, value')
    .in('key', ['gmail_access_token', 'gmail_email', 'gmail_token_expiry', 'gmail_refresh_token']);

  const s = Object.fromEntries((data || []).map(r => [r.key, r.value]));
  return {
    connected:     !!(s.gmail_access_token && s.gmail_email),
    email:         s.gmail_email    || null,
    access_token:  s.gmail_access_token  || null,
    refresh_token: s.gmail_refresh_token || null,
    expiry:        parseInt(s.gmail_token_expiry || '0'),
  };
}

async function getValidGmailToken() {
  const status = await getGmailStatus();
  if (!status.connected) {
    showToast('Gmail non connecté — cliquez sur "Connecter Gmail"', 'error');
    return null;
  }

  // Token expiré ou expire dans moins de 2 min → essayer refresh
  if (Date.now() > status.expiry - 120_000 && status.refresh_token) {
    try {
      const newToken = await _refreshToken(status.refresh_token);
      if (newToken) {
        await _saveTokens({ ...newToken, email: status.email });
        return newToken.access_token;
      }
    } catch (e) {
      console.warn('[gmailRefresh]', e.message);
    }
  }

  return status.access_token;
}

async function _refreshToken(refresh_token) {
  /* Nécessite un proxy côté serveur avec le CLIENT_SECRET.
     Implémentez window._gmailRefreshToken = async (rt) => {…} dans votre Edge Function. */
  if (typeof window._gmailRefreshToken === 'function') {
    return window._gmailRefreshToken(refresh_token);
  }
  return null;
}

async function disconnectGmail() {
  await Promise.all([
    setSetting('gmail_access_token',  ''),
    setSetting('gmail_refresh_token', ''),
    setSetting('gmail_email',         ''),
    setSetting('gmail_token_expiry',  ''),
  ]);
  showToast('Gmail déconnecté', 'success');
  if (typeof renderEmail === 'function') renderEmail();
}

/* ────────────────────────────────────────────────────────────────
   ENVOI GMAIL API
──────────────────────────────────────────────────────────────── */
async function gmailSend({ to, cc = '', subject, htmlBody, attachments = [] }) {
  const token = await getValidGmailToken();
  if (!token) return false;

  const boundary = `qr_boundary_${Date.now()}`;

  // Encode subject UTF-8 base64
  const subjectEncoded = `=?UTF-8?B?${btoa(unescape(encodeURIComponent(subject)))}?=`;
  const htmlEncoded    = btoa(unescape(encodeURIComponent(htmlBody)));

  const mimeLines = [
    `MIME-Version: 1.0`,
    `To: ${to}`,
    cc ? `Cc: ${cc}` : null,
    `Subject: ${subjectEncoded}`,
    `Content-Type: multipart/mixed; boundary="${boundary}"`,
    ``,
    `--${boundary}`,
    `Content-Type: text/html; charset=UTF-8`,
    `Content-Transfer-Encoding: base64`,
    ``,
    htmlEncoded,
  ].filter(l => l !== null);

  for (const att of attachments) {
    if (!att.data || !att.name) continue;
    mimeLines.push(
      `--${boundary}`,
      `Content-Type: ${att.mimeType || 'application/octet-stream'}; name="${att.name}"`,
      `Content-Transfer-Encoding: base64`,
      `Content-Disposition: attachment; filename="${att.name}"`,
      ``,
      att.data
    );
  }
  mimeLines.push(`--${boundary}--`);

  // Gmail API : base64url-encode (sans + ni /)
  const raw = btoa(mimeLines.join('\r\n'))
    .replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');

  const res = await fetch(
    'https://gmail.googleapis.com/gmail/v1/users/me/messages/send',
    {
      method: 'POST',
      headers: {
        Authorization: `Bearer ${token}`,
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({ raw }),
    }
  );

  if (!res.ok) {
    const err = await res.json().catch(() => ({}));
    throw new Error(err?.error?.message || `HTTP ${res.status}`);
  }

  return await res.json(); // { id, threadId, labelIds }
}

