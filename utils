/* ────────────────────────────────────────────────────────────────
   OAUTH FLOW
──────────────────────────────────────────────────────────────── */
function startGmailAuth() {
  const cfg = _gmailCfg();
  if (!cfg.CLIENT_ID || cfg.CLIENT_ID === 'VOTRE_GOOGLE_CLIENT_ID') {
    showToast('Clé Google Client ID non configurée dans utils/config.js', 'error');
    return;
  }

  const params = new URLSearchParams({
    client_id:     cfg.CLIENT_ID,
    redirect_uri:  cfg.REDIRECT_URI,
    response_type: 'code',
    scope:         cfg.SCOPES,
    access_type:   'offline',
    prompt:        'consent',
  });

  const popup = window.open(
    `https://accounts.google.com/o/oauth2/v2/auth?${params}`,
    'gmail_auth',
    'width=520,height=640,left=200,top=100'
  );

  if (!popup) {
    showToast('Popup bloquée — autorisez les popups pour ce site', 'error');
    return;
  }

  // Écoute le callback postMessage depuis oauth-callback.html
  const handler = async (e) => {
    if (e.origin !== window.location.origin) return;
    if (e.data?.type !== 'gmail_auth_code') return;
    window.removeEventListener('message', handler);
    if (e.data.code) {
      await _handleAuthCode(e.data.code);
    } else if (e.data.error) {
      showToast('Autorisation Gmail refusée : ' + e.data.error, 'error');
    }
  };
  window.addEventListener('message', handler);
}

