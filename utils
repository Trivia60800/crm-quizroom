async function importDealsFromCSV(rows) {
  const results = { ok: 0, errors: 0 };
  for (const row of rows) {
    try {
      await createDeal(row);
      results.ok++;
    } catch (e) {
      console.warn('[importCSV row error]', e.message, row);
      results.errors++;
    }
  }
  return results;
}

